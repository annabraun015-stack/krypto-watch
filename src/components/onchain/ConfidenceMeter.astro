---
/**
 * ConfidenceMeter.astro — Visual confidence score widget
 */
interface Props {
  score: number;    // 0–100
  label?: string;
  size?: 'sm' | 'md' | 'lg';
}
const { score, label = 'Confidence', size = 'md' } = Astro.props;
const color = score >= 70 ? 'high' : score >= 45 ? 'medium' : 'low';
const radius = size === 'lg' ? 38 : size === 'md' ? 30 : 22;
const stroke = size === 'lg' ? 6 : 5;
const sz = (radius + stroke) * 2;
const circumference = 2 * Math.PI * radius;
const dashOffset = circumference * (1 - score / 100);
---

<div class={`cm-root cm--${size}`} aria-label={`${label}: ${score}%`}>
  <svg width={sz} height={sz} viewBox={`0 0 ${sz} ${sz}`} role="img" aria-hidden="true">
    <!-- Track -->
    <circle
      cx={sz/2} cy={sz/2} r={radius}
      fill="none"
      stroke="oklch(25% 0.05 250 / 0.4)"
      stroke-width={stroke}
    />
    <!-- Progress -->
    <circle
      cx={sz/2} cy={sz/2} r={radius}
      fill="none"
      class={`cm-arc cm-arc--${color}`}
      stroke-width={stroke}
      stroke-linecap="round"
      stroke-dasharray={circumference}
      stroke-dashoffset={dashOffset}
      transform={`rotate(-90 ${sz/2} ${sz/2})`}
    />
    <!-- Score text -->
    <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" class={`cm-text cm-text--${size}`}>
      {score}
    </text>
  </svg>
  {label && <div class="cm-label">{label}</div>}
</div>

<style>
.cm-root { display: inline-flex; flex-direction: column; align-items: center; gap: 0.375rem; }
.cm-arc { transition: stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1); }
.cm-arc--high   { stroke: oklch(72% 0.2 145); filter: drop-shadow(0 0 6px oklch(72% 0.2 145 / 0.6)); }
.cm-arc--medium { stroke: oklch(75% 0.18 60); filter: drop-shadow(0 0 6px oklch(75% 0.18 60 / 0.5)); }
.cm-arc--low    { stroke: oklch(65% 0.25 25); filter: drop-shadow(0 0 6px oklch(65% 0.25 25 / 0.5)); }
.cm-text { font-family: var(--font-display); fill: var(--color-text-primary); font-weight: 800; }
.cm-text--lg { font-size: 1rem; }
.cm-text--md { font-size: 0.8125rem; }
.cm-text--sm { font-size: 0.625rem; }
.cm-label { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-muted); }
</style>
