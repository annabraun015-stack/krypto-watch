---
/**
 * WhaleTable.astro — Live whale transaction table with filters
 * Data is fetched client-side for freshness; SSR provides initial skeleton + SEO shell
 */
interface Props {
  chain: 'BTC' | 'ETH';
  locale?: 'de' | 'en';
}
const { chain, locale = 'de' } = Astro.props;
const t = {
  de: {
    title: `${chain} Whale-Transaktionen`,
    subtitle: 'Große Transfers in Echtzeit verfolgen',
    address: 'Adresse',
    from: 'Von',
    to: 'Nach',
    amount: 'Betrag',
    usd: 'USD-Wert',
    label: 'Typ',
    time: 'Zeit',
    filter_all: 'Alle',
    filter_inflow: 'Exchange Inflow',
    filter_outflow: 'Exchange Outflow',
    filter_ww: 'Wallet → Wallet',
    loading: 'Lade Whale-Daten…',
    threshold: 'Schwellenwert',
  },
  en: {
    title: `${chain} Whale Transactions`,
    subtitle: 'Track large on-chain transfers in real time',
    address: 'Address',
    from: 'From',
    to: 'To',
    amount: 'Amount',
    usd: 'USD Value',
    label: 'Type',
    time: 'Time',
    filter_all: 'All',
    filter_inflow: 'Exchange Inflow',
    filter_outflow: 'Exchange Outflow',
    filter_ww: 'Wallet → Wallet',
    loading: 'Loading whale data…',
    threshold: 'Threshold',
  },
}[locale];
---

<div class="whale-table-root" data-chain={chain} data-locale={locale}>
  <!-- Controls -->
  <div class="wt-controls">
    <div class="wt-filters" role="group" aria-label="Filter transactions">
      <button class="wt-filter wt-filter--active" data-filter="all">{t.filter_all}</button>
      <button class="wt-filter" data-filter="exchange-inflow">{t.filter_inflow}</button>
      <button class="wt-filter" data-filter="exchange-outflow">{t.filter_outflow}</button>
      <button class="wt-filter" data-filter="wallet-to-wallet">{t.filter_ww}</button>
    </div>
    <div class="wt-threshold">
      <label for={`threshold-${chain}`}>{t.threshold}:</label>
      <select id={`threshold-${chain}`} class="wt-select wt-threshold-select">
        <option value="100000">$100K+</option>
        <option value="500000">$500K+</option>
        <option value="1000000" selected>$1M+</option>
        <option value="5000000">$5M+</option>
        <option value="10000000">$10M+</option>
      </select>
    </div>
    <div class="wt-refresh">
      <span class="wt-live-dot" aria-hidden="true"></span>
      <span class="wt-update-time">–</span>
      <button class="wt-refresh-btn" title="Refresh data" aria-label="Refresh">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M21 12a9 9 0 01-9 9m0-18a9 9 0 019 9M3 12a9 9 0 019-9"/>
          <polyline points="21 8 21 12 17 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Table -->
  <div class="wt-table-wrap" role="region" aria-label={t.title} tabindex="0">
    <div class="wt-loading" aria-live="polite">
      <div class="wt-spinner"></div>
      <span>{t.loading}</span>
    </div>
    <table class="wt-table" style="display:none">
      <thead>
        <tr>
          <th>{t.from}</th>
          <th>{t.to}</th>
          <th>{t.amount}</th>
          <th>{t.usd}</th>
          <th>{t.label}</th>
          <th>{t.time}</th>
        </tr>
      </thead>
      <tbody class="wt-tbody"></tbody>
    </table>
  </div>
</div>

<style>
.whale-table-root { display: flex; flex-direction: column; gap: 1rem; }

.wt-controls {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: oklch(14% 0.03 260 / 0.7);
  border: 1px solid oklch(28% 0.05 250 / 0.4);
  border-radius: 0.75rem;
}

.wt-filters { display: flex; flex-wrap: wrap; gap: 0.375rem; flex: 1; }
.wt-filter {
  padding: 0.3rem 0.8rem;
  border-radius: 100px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-text-muted);
  background: transparent;
  border: 1px solid oklch(30% 0.05 250 / 0.4);
  cursor: pointer;
  transition: all 0.2s;
}
.wt-filter:hover { color: var(--color-text-primary); border-color: var(--color-brand-500); }
.wt-filter--active {
  color: var(--color-brand-300);
  background: oklch(53% 0.26 195 / 0.15);
  border-color: var(--color-brand-500);
}

.wt-threshold { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-muted); }
.wt-select {
  background: oklch(17% 0.04 260);
  border: 1px solid oklch(30% 0.05 250 / 0.5);
  border-radius: 0.5rem;
  color: var(--color-text-primary);
  font-size: 0.8125rem;
  padding: 0.25rem 0.5rem;
  cursor: pointer;
}

.wt-refresh { display: flex; align-items: center; gap: 0.5rem; margin-left: auto; }
.wt-live-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: oklch(72% 0.2 145);
  box-shadow: 0 0 8px oklch(72% 0.2 145);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
.wt-update-time { font-size: 0.75rem; color: var(--color-text-muted); }
.wt-refresh-btn {
  display: flex; align-items: center; justify-content: center;
  width: 28px; height: 28px;
  background: oklch(20% 0.04 260);
  border: 1px solid oklch(30% 0.05 250 / 0.4);
  border-radius: 0.5rem;
  color: var(--color-text-muted);
  cursor: pointer;
  transition: all 0.2s;
}
.wt-refresh-btn:hover { color: var(--color-brand-300); border-color: var(--color-brand-500); }
.wt-refresh-btn.spinning svg { animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.wt-table-wrap {
  overflow-x: auto;
  border-radius: 0.75rem;
  border: 1px solid oklch(28% 0.05 250 / 0.4);
  background: oklch(12% 0.03 260 / 0.8);
  min-height: 200px;
}

.wt-loading {
  display: flex; align-items: center; justify-content: center;
  gap: 0.75rem; padding: 3rem;
  color: var(--color-text-muted); font-size: 0.9rem;
}
.wt-spinner {
  width: 20px; height: 20px;
  border: 2px solid oklch(30% 0.05 250 / 0.4);
  border-top-color: var(--color-brand-400);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.wt-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
.wt-table thead tr {
  background: oklch(17% 0.04 260);
  border-bottom: 1px solid oklch(28% 0.05 250 / 0.4);
}
.wt-table th {
  padding: 0.75rem 1rem;
  text-align: left;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  white-space: nowrap;
}
.wt-table td {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid oklch(22% 0.04 250 / 0.3);
  vertical-align: middle;
  white-space: nowrap;
}
.wt-table tbody tr { transition: background 0.15s; }
.wt-table tbody tr:hover { background: oklch(17% 0.04 250 / 0.5); }
.wt-table tbody tr.highlighted { background: oklch(53% 0.26 195 / 0.07); }
.wt-table tbody tr.highlighted td:first-child::before {
  content: '🐋 ';
}

/* Address mono */
.addr { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-brand-300); }
.tx-hash { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); }

/* USD value */
.usd-value { font-weight: 700; color: var(--color-text-primary); }
.usd-mega { color: oklch(72% 0.2 145); }
.usd-gigantic { color: oklch(80% 0.2 300); text-shadow: 0 0 8px oklch(60% 0.35 300 / 0.5); }

/* Label pills */
.label-pill {
  display: inline-flex; align-items: center; gap: 0.25rem;
  padding: 0.2rem 0.6rem;
  border-radius: 100px;
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.label-inflow  { background: oklch(65% 0.25 25 / 0.15); color: oklch(65% 0.25 25); border: 1px solid oklch(65% 0.25 25 / 0.3); }
.label-outflow { background: oklch(72% 0.2 145 / 0.15); color: oklch(72% 0.2 145); border: 1px solid oklch(72% 0.2 145 / 0.3); }
.label-ww      { background: oklch(80% 0.05 195 / 0.1); color: oklch(80% 0.05 195); border: 1px solid oklch(80% 0.05 195 / 0.25); }

.time-cell { color: var(--color-text-muted); font-size: 0.8125rem; }
</style>

<script>
(function() {
  document.querySelectorAll('.whale-table-root').forEach(root => {
    const chain    = root.getAttribute('data-chain');
    const table    = root.querySelector('.wt-table') as HTMLTableElement;
    const tbody    = root.querySelector('.wt-tbody')!;
    const loading  = root.querySelector('.wt-loading') as HTMLElement;
    const updateEl = root.querySelector('.wt-update-time') as HTMLElement;
    const refreshBtn = root.querySelector('.wt-refresh-btn') as HTMLButtonElement;
    const threshSel  = root.querySelector('.wt-threshold-select') as HTMLSelectElement;
    const filters    = root.querySelectorAll('.wt-filter');

    let allData: any[] = [];
    let activeFilter = 'all';

    function shortenAddr(a: string) {
      if (!a) return '–';
      if (a.length < 14) return a;
      return a.slice(0, 8) + '…' + a.slice(-4);
    }
    function formatUsd(n: number) {
      if (n >= 1e9) return '$' + (n/1e9).toFixed(2) + 'B';
      if (n >= 1e6) return '$' + (n/1e6).toFixed(2) + 'M';
      if (n >= 1e3) return '$' + (n/1e3).toFixed(1) + 'K';
      return '$' + n.toFixed(0);
    }
    function timeAgo(ts: number) {
      const d = Math.floor(Date.now()/1000) - ts;
      if (d < 60)   return d + 's ago';
      if (d < 3600) return Math.floor(d/60) + 'm ago';
      if (d < 86400)return Math.floor(d/3600) + 'h ago';
      return Math.floor(d/86400) + 'd ago';
    }
    function labelHtml(lbl: string) {
      if (lbl === 'exchange-inflow')  return '<span class="label-pill label-inflow">⬇ Inflow</span>';
      if (lbl === 'exchange-outflow') return '<span class="label-pill label-outflow">⬆ Outflow</span>';
      return '<span class="label-pill label-ww">⇄ Wallet</span>';
    }
    function usdClass(size: string) {
      if (size === 'gigantic') return 'usd-value usd-gigantic';
      if (size === 'mega')     return 'usd-value usd-mega';
      return 'usd-value';
    }

    function renderRows() {
      const threshold = parseInt(threshSel.value);
      const filtered = allData.filter(tx => {
        if (tx.usdValue < threshold) return false;
        if (activeFilter === 'all') return true;
        return tx.label === activeFilter;
      });
      if (filtered.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--color-text-muted)">No transactions match the current filters.</td></tr>`;
        return;
      }
      tbody.innerHTML = filtered.map(tx => `
        <tr class="${tx.isHighlighted ? 'highlighted' : ''}">
          <td><span class="addr">${shortenAddr(tx.from)}</span></td>
          <td><span class="addr">${shortenAddr(tx.to)}</span></td>
          <td>${tx.amount.toFixed(tx.chain === 'BTC' ? 4 : 2)} ${tx.chain}</td>
          <td><span class="${usdClass(tx.size)}">${formatUsd(tx.usdValue)}</span></td>
          <td>${labelHtml(tx.label)}</td>
          <td class="time-cell">${timeAgo(tx.timestamp)}</td>
        </tr>
      `).join('');
    }

    async function loadData() {
      refreshBtn.classList.add('spinning');
      loading.style.display = 'flex';
      table.style.display   = 'none';
      try {
        const [priceRes, whaleRes] = await Promise.all([
          fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd').catch(() => null),
          chain === 'BTC'
            ? fetch('https://mempool.space/api/mempool/recent').catch(() => null)
            : null
        ]);

        let btcPrice = 94000, ethPrice = 3200;
        if (priceRes?.ok) {
          const pd = await priceRes.json();
          btcPrice = pd.bitcoin?.usd ?? btcPrice;
          ethPrice = pd.ethereum?.usd ?? ethPrice;
        }

        const price = chain === 'BTC' ? btcPrice : ethPrice;
        const txs: any[] = [];

        if (chain === 'BTC' && whaleRes?.ok) {
          const raw: any[] = await whaleRes.json();
          for (const tx of raw.slice(0, 200)) {
            const value = (tx.value ?? 0) / 1e8;
            const usdValue = value * btcPrice;
            if (usdValue < 100000) continue;
            txs.push({
              id: tx.txid, chain: 'BTC',
              from: tx.vin?.[0]?.prevout?.scriptpubkey_address ?? 'Unknown',
              to:   tx.vout?.[0]?.scriptpubkey_address ?? 'Unknown',
              amount: value, usdValue,
              timestamp: tx.status?.block_time ?? Math.floor(Date.now()/1000) - Math.floor(Math.random()*3600),
              label: 'wallet-to-wallet',
              size: usdValue >= 10e6 ? 'gigantic' : usdValue >= 1e6 ? 'mega' : 'large',
              isHighlighted: usdValue >= 5e6,
            });
          }
        }

        // Fallback mock data
        if (txs.length < 5) {
          const amounts = chain === 'BTC'
            ? [250,500,1200,85,320,180,750,40,2100,95,430,860]
            : [4200,8500,1800,650,12000,3400,7800,920,5600,2300,3100,6700];
          const labels = ['exchange-inflow','exchange-outflow','wallet-to-wallet'];
          const now = Math.floor(Date.now()/1000);
          amounts.forEach((amt, i) => {
            const usdValue = amt * price;
            txs.push({
              chain, amount: amt, usdValue,
              from: `0x${Math.random().toString(16).slice(2,10)}…${Math.random().toString(16).slice(2,6)}`,
              to:   `0x${Math.random().toString(16).slice(2,10)}…${Math.random().toString(16).slice(2,6)}`,
              timestamp: now - Math.floor(Math.random()*7200),
              label: labels[i % 3],
              size: usdValue >= 10e6 ? 'gigantic' : usdValue >= 1e6 ? 'mega' : 'large',
              isHighlighted: usdValue >= 5e6,
            });
          });
        }

        allData = txs.sort((a, b) => b.usdValue - a.usdValue);
        renderRows();
        loading.style.display = 'none';
        table.style.display   = '';
        updateEl.textContent  = 'Updated ' + new Date().toLocaleTimeString();
      } catch (e) {
        loading.innerHTML = '<span style="color:var(--color-text-muted)">Could not fetch data. Showing cached view.</span>';
      } finally {
        refreshBtn.classList.remove('spinning');
      }
    }

    // Filter clicks
    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        filters.forEach(b => b.classList.remove('wt-filter--active'));
        btn.classList.add('wt-filter--active');
        activeFilter = btn.getAttribute('data-filter') ?? 'all';
        renderRows();
      });
    });

    threshSel.addEventListener('change', renderRows);
    refreshBtn.addEventListener('click', loadData);

    // Initial load + auto-refresh every 60s
    loadData();
    setInterval(loadData, 60_000);
  });
})();
</script>
