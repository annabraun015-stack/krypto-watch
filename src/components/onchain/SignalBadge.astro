---
interface Props {
  signal: 'bullish' | 'bearish' | 'neutral';
  reason?: string;
  size?: 'sm' | 'md' | 'lg';
}
const { signal, reason, size = 'md' } = Astro.props;
const config = {
  bullish: { label: '▲ Bullish Signal', cls: 'signal-bullish', icon: '📈' },
  bearish: { label: '▼ Bearish Signal', cls: 'signal-bearish', icon: '📉' },
  neutral: { label: '◆ Neutral', cls: 'signal-neutral', icon: '➖' },
}[signal];
---

<span class={`signal-badge signal-badge--${size} ${config.cls}`} title={reason ?? ''}>
  {config.icon} {config.label}
</span>

<style>
.signal-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.25rem 0.75rem;
  border-radius: 100px;
  font-weight: 700;
  letter-spacing: 0.02em;
  font-size: 0.75rem;
  white-space: nowrap;
}
.signal-badge--sm { font-size: 0.6875rem; padding: 0.2rem 0.6rem; }
.signal-badge--lg { font-size: 0.875rem; padding: 0.375rem 1rem; }

.signal-bullish {
  background: oklch(72% 0.2 145 / 0.15);
  color: oklch(72% 0.2 145);
  border: 1px solid oklch(72% 0.2 145 / 0.3);
  box-shadow: 0 0 12px -4px oklch(72% 0.2 145 / 0.4);
}
.signal-bearish {
  background: oklch(65% 0.25 25 / 0.15);
  color: oklch(65% 0.25 25);
  border: 1px solid oklch(65% 0.25 25 / 0.3);
  box-shadow: 0 0 12px -4px oklch(65% 0.25 25 / 0.4);
}
.signal-neutral {
  background: oklch(80% 0.05 195 / 0.1);
  color: oklch(80% 0.05 195);
  border: 1px solid oklch(80% 0.05 195 / 0.25);
}
</style>
