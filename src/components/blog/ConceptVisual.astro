---

interface Props {
  src: string;
  alt: string;
  type: 'diagram' | 'flow' | 'chart' | 'comparison';
  caption: string;
}

const { src, alt, type, caption } = Astro.props;

const typeLabel = {
  diagram: 'Diagram',
  flow: 'Process Flow',
  chart: 'Data Visualization',
  comparison: 'Comparison'
};

const typeColor = {
  diagram: 'text-blue-400 border-blue-400/30 bg-blue-400/5',
  flow: 'text-emerald-400 border-emerald-400/30 bg-emerald-400/5',
  chart: 'text-amber-400 border-amber-400/30 bg-amber-400/5',
  comparison: 'text-purple-400 border-purple-400/30 bg-purple-400/5'
};
---

<figure class="my-12">
  <div class="relative rounded-2xl overflow-hidden border border-white/10 bg-surface-900 shadow-2xl">
    <!-- Visual Type Badge -->
    <div class={`absolute top-4 left-4 z-10 px-3 py-1 rounded-full border text-[10px] font-bold uppercase tracking-widest ${typeColor[type]}`}>
      {typeLabel[type]}
    </div>

    <!-- Image -->
    <img 
      src={src} 
      alt={alt} 
      class="w-full h-auto object-cover opacity-90 hover:opacity-100 transition-opacity duration-500"
    />

    <!-- Decorative Corner -->
    <div class="absolute bottom-0 right-0 w-24 h-24 bg-gradient-to-tl from-brand-500/10 to-transparent pointer-events-none"></div>
  </div>
  
  <figcaption class="mt-4 px-4 text-center">
    <div class="text-text-primary font-semibold text-sm mb-1">{alt}</div>
    <div class="text-text-muted text-xs leading-relaxed italic">{caption}</div>
  </figcaption>
</figure>
