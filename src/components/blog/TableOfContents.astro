---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
  locale?: string;
}

const { headings, locale = 'en' } = Astro.props;

// Filter to show only h2 and h3
const filteredHeadings = headings.filter(h => h.depth > 1 && h.depth <= 3);

const labels = {
  en: {
    title: 'Table of Contents',
    hint: 'Click to expand navigation'
  },
  de: {
    title: 'Inhaltsverzeichnis',
    hint: 'Klicken zum Aufklappen'
  }
};

const t = labels[locale as keyof typeof labels] || labels.en;
---

<div class="sidebar-card toc-container" id="toc-container">
  <button class="toc-toggle" id="toc-toggle" aria-expanded="false" aria-controls="toc-list-wrapper">
    <h3 class="sidebar-card-title">{t.title}</h3>
    <svg class="toc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
  
  <div class="toc-list-wrapper" id="toc-list-wrapper">
    <nav class="toc-nav" aria-label={t.title}>
      {filteredHeadings.length > 0 ? (
        <ul class="toc-list">
          {filteredHeadings.map(heading => (
            <li class={`toc-item depth-${heading.depth}`}>
              <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="sidebar-toc-hint">{t.hint}</p>
      )}
    </nav>
  </div>
</div>

<style>
  .toc-container {
    display: flex;
    flex-direction: column;
    padding: 0 !important; /* Managed by toggle button padding */
    overflow: hidden;
  }

  .toc-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }

  .toc-toggle:hover {
    background: oklch(20% 0.04 250 / 0.3);
  }

  .toc-toggle .sidebar-card-title {
    margin-bottom: 0;
  }

  .toc-chevron {
    color: var(--color-text-muted);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Grid-based height interpolation */
  .toc-list-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding-inline: 1.25rem;
  }

  /* When expanded */
  .toc-container.is-expanded .toc-list-wrapper {
    grid-template-rows: 1fr;
    padding-bottom: 1.25rem;
  }

  .toc-container.is-expanded .toc-chevron {
    transform: rotate(180deg);
    color: var(--color-brand-400);
  }

  .toc-nav {
    overflow: hidden;
    min-height: 0;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.5rem;
  }

  .toc-item {
    line-height: 1.4;
  }

  .toc-item.depth-3 {
    padding-left: 1rem;
    font-size: 0.875rem;
  }

  .toc-link {
    display: block;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: all 0.2s ease;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    margin-left: -0.75rem;
  }

  .toc-link:hover {
    color: var(--color-brand-300);
    padding-left: 1rem;
  }

  .toc-link.active {
    color: var(--color-brand-300);
    font-weight: 600;
    border-left-color: var(--color-brand-500);
    padding-left: 1rem;
  }

  .sidebar-toc-hint {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    padding-top: 0.5rem;
  }

  /* Hide scrollbar but keep functionality */
  .toc-container {
    scrollbar-width: none;
  }
  .toc-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function setupTOC() {
    const container = document.getElementById('toc-container');
    const toggle = document.getElementById('toc-toggle');
    const links = document.querySelectorAll('.toc-link');

    if (!container || !toggle) return;

    // Toggle expansion
    toggle.addEventListener('click', () => {
      const isExpanded = container.classList.toggle('is-expanded');
      toggle.setAttribute('aria-expanded', isExpanded.toString());
    });

    // Scroll Spy Logic
    const observerOptions = {
      root: null,
      rootMargin: '-10% 0% -80% 0%',
      threshold: 0
    };

    const sections = Array.from(links).map(link => {
      const slug = link.getAttribute('data-slug');
      return document.getElementById(slug!);
    }).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          links.forEach(link => {
            if (link.getAttribute('data-slug') === id) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach(section => {
      if (section) observer.observe(section);
    });

    // Close on link click (optional, but good for mobile/narrow views)
    links.forEach(link => {
      link.addEventListener('click', () => {
        // We keep it open so they see where they went, but on mobile you might want close
      });
    });
  }

  // Initialize on page load
  setupTOC();

  // Re-initialize on view transitions
  document.addEventListener('astro:after-swap', setupTOC);
</script>
