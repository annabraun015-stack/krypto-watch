---
interface Props {
  locale: 'de' | 'en';
  tr: any;
}

const { locale, tr } = Astro.props;

// Mock historical data (in a real app, you'd fetch more from the API)
const history = [
  { day: "YESTERDAY", val: 54, status: "NEUTRAL" },
  { day: "LAST WEEK", val: 62, status: "GREED" },
  { day: "LAST MONTH", val: 38, status: "FEAR" },
  { day: "LAST YEAR", val: 74, status: "EXTREME_GREED" }
];
---

<section class="sentiment-history">
  <div class="section-header">
    <div class="header-line"></div>
    <h2 class="title">{tr.sentiment.historyTitle}</h2>
  </div>

  <div class="history-grid">
    {history.map((item) => (
      <div class="history-card">
        <div class="card-meta">
          <span class="meta-tag">SYNC_STABLE</span>
          <span class="meta-tag">IDX_2026</span>
        </div>
        <div class="card-glow"></div>
        <div class="card-header">
          <span class="day">{item.day}</span>
          <span class="val">{item.val}</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill pulse-bar" style={`width: ${item.val}%; background: ${item.val > 50 ? 'var(--color-brand-500)' : 'oklch(60% 0.2 20)'};`}></div>
        </div>
        <div class="card-footer">
          <span class="status">{item.status}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .sentiment-history {
    margin-top: 5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .header-line {
    width: 60px;
    height: 4px;
    background: var(--color-brand-500);
    border-radius: 2px;
    box-shadow: 0 0 10px var(--color-brand-500 / 0.5);
  }

  .title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: var(--color-text-primary);
  }

  .history-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .history-card {
    background: oklch(12% 0.03 250 / 0.6);
    border: 1px solid oklch(25% 0.05 250 / 0.4);
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    /* Clipped corners */
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 15px),
      calc(100% - 15px) 100%,
      0 100%
    );
  }

  .history-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--color-brand-500);
    opacity: 0.2;
    transition: opacity 0.3s;
  }

  .history-card:hover {
    border-color: var(--color-brand-400);
    transform: translateY(-8px);
    background: oklch(15% 0.04 250 / 0.8);
  }

  .history-card:hover::before {
    opacity: 1;
    box-shadow: 0 0 15px var(--color-brand-500);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .meta-tag {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--color-brand-400 / 0.4);
    letter-spacing: 0.1em;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, var(--color-brand-500 / 0.05) 0%, transparent 60%);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .day {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 800;
    color: var(--color-text-muted);
    letter-spacing: 0.15em;
  }

  .val {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-text-primary);
    line-height: 1;
    text-shadow: 0 0 20px oklch(0% 0 0 / 0.3);
  }

  .progress-bar {
    height: 4px;
    background: oklch(20% 0.05 250 / 0.3);
    border-radius: 2px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
  }

  .progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 1s ease-out;
  }

  .pulse-bar {
    animation: bar-pulse 2s infinite ease-in-out;
  }

  @keyframes bar-pulse {
    0%, 100% { opacity: 0.8; box-shadow: 0 0 5px currentColor; }
    50% { opacity: 1; box-shadow: 0 0 15px currentColor; }
  }

  .card-footer {
    position: relative;
    z-index: 2;
  }

  .status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 900;
    color: var(--color-brand-400);
    letter-spacing: 0.2em;
  }
</style>
