---
import { footerLinks, socialLinks, siteConfig } from '../config/site';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const tr = t(locale);
const links = footerLinks[locale];
const altLocale = locale === 'de' ? 'en' : 'de';
const altPath = locale === 'de'
  ? `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/en/, '') || '/';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <!-- Gradient separator -->
  <div class="footer-divider" aria-hidden="true"></div>

  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href={locale === 'de' ? '/' : '/en/'} class="footer-logo" aria-label="KryptoWatch">
          <div class="logo-mark" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="url(#fLogoGrad)"/>
              <path d="M10 22V10l6 4 6-4v12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 14v8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <defs>
                <linearGradient id="fLogoGrad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#00f2ff"/><stop offset="1" stop-color="#bc00ff"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <span class="footer-logo-text">Krypto<span>Watch</span></span>
        </a>
        <p class="footer-desc">{tr.footer.description}</p>

        <!-- Social links -->
        <div class="footer-socials" role="list" aria-label="Social Media Links">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              role="listitem"
            >
              {s.icon === 'twitter' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === 'telegram' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                </svg>
              )}
              {s.icon === 'linkedin' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <div class="footer-col">
        <h3 class="footer-col-title">Navigation</h3>
        <nav aria-label="Footer Navigation">
          <ul class="footer-links" role="list">
            {links.map((link) => (
              <li role="listitem">
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Categories -->
      <div class="footer-col">
        <h3 class="footer-col-title">{locale === 'de' ? 'Kategorien' : 'Categories'}</h3>
        <ul class="footer-links" role="list">
          <li role="listitem"><a href={locale === 'de' ? '/blog/?cat=bitcoin' : '/en/blog/?cat=bitcoin'} class="footer-link">₿ Bitcoin</a></li>
          <li role="listitem"><a href={locale === 'de' ? '/blog/?cat=ethereum' : '/en/blog/?cat=ethereum'} class="footer-link">Ξ Ethereum</a></li>
          <li role="listitem"><a href={locale === 'de' ? '/blog/?cat=defi' : '/en/blog/?cat=defi'} class="footer-link">🔗 DeFi</a></li>
          <li role="listitem"><a href={locale === 'de' ? '/blog/?cat=altcoins' : '/en/blog/?cat=altcoins'} class="footer-link">🪙 Altcoins</a></li>
          <li role="listitem"><a href={locale === 'de' ? '/blog/?cat=regulation' : '/en/blog/?cat=regulation'} class="footer-link">⚖️ {locale === 'de' ? 'Regulierung' : 'Regulation'}</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer-col">
        <h3 class="footer-col-title">{locale === 'de' ? 'Newsletter' : 'Newsletter'}</h3>
        <p class="footer-newsletter-desc">
          {locale === 'de'
            ? 'Täglich die wichtigsten Krypto-News in Ihrem Postfach.'
            : 'Daily top crypto news delivered to your inbox.'}
        </p>
        <form class="newsletter-form" id="footer-newsletter" aria-label="Newsletter Anmeldung">
          <div class="newsletter-row">
            <input
              type="email"
              name="email"
              placeholder={locale === 'de' ? 'ihre@email.de' : 'your@email.com'}
              class="form-input newsletter-input"
              required
              aria-label={locale === 'de' ? 'E-Mail-Adresse' : 'Email Address'}
            />
            <button type="submit" class="btn btn-primary newsletter-btn" aria-label={locale === 'de' ? 'Abonnieren' : 'Subscribe'}>
              →
            </button>
          </div>
        </form>

        <!-- Language switcher -->
        <div class="footer-lang">
          <span class="footer-lang-label">{locale === 'de' ? 'Sprache:' : 'Language:'}</span>
          <a href={altPath} class="footer-lang-link">
            {altLocale === 'en' ? '🇬🇧 English' : '🇩🇪 Deutsch'}
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">{tr.footer.copyright.replace('2025', String(currentYear))}</p>
      <p class="footer-disclaimer">{tr.footer.disclaimer}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: oklch(8% 0.02 260);
    border-top: 1px solid oklch(20% 0.04 195 / 0.5);
    padding-top: 4rem;
    padding-bottom: 2rem;
    position: relative;
  }

  .footer-divider {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand-500), var(--color-accent-400), transparent);
    opacity: 0.6;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 3rem; }
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .footer-logo-text span { color: var(--color-brand-400); }

  .footer-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 300px;
    margin-bottom: 1.5rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(17% 0.04 260);
    border: 1px solid oklch(28% 0.05 195 / 0.5);
    border-radius: 0.5rem;
    color: var(--color-text-secondary);
    transition: all 0.25s;
    text-decoration: none;
  }

  .social-link:hover {
    border-color: var(--color-brand-400);
    color: var(--color-brand-300);
    background: oklch(20% 0.05 250);
    transform: translateY(-2px);
  }

  /* Columns */
  .footer-col-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
  }

  .footer-link:hover { color: var(--color-brand-300); }

  /* Newsletter */
  .footer-newsletter-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .newsletter-form { margin-bottom: 1.25rem; }

  .newsletter-row {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-input { flex: 1; }

  .newsletter-btn {
    padding: 0.75rem 1rem;
    flex-shrink: 0;
    font-size: 1.125rem;
  }

  /* Language switcher in footer */
  .footer-lang {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .footer-lang-label { color: var(--color-text-muted); }

  .footer-lang-link {
    color: var(--color-brand-300);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-lang-link:hover { color: var(--color-brand-200); }

  /* Bottom bar */
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid oklch(20% 0.04 195 / 0.4);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copyright, .footer-disclaimer {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  const form = document.getElementById('footer-newsletter') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]') as HTMLInputElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (!input.value) return;
      btn.textContent = '✓';
      btn.disabled = true;
      input.value = '';
      setTimeout(() => { btn.textContent = '→'; btn.disabled = false; }, 3000);
    });
  }
</script>
