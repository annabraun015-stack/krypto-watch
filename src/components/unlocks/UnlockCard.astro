---
import { calculateSupplyShock } from '../../lib/supabase';

interface Props {
  unlock: {
    coinId: string;
    symbol: string;
    name: string;
    unlockDate: Date;
    amount: number;
    amountUsd: number;
    percentOfCirculating: number;
    category: string;
    isCliff: boolean;
  };
}

const { unlock } = Astro.props;

const shock = calculateSupplyShock(unlock.amount, (unlock.amount / unlock.percentOfCirculating) * 100);

const isFuture = unlock.unlockDate.getTime() > Date.now();
const dateStr = unlock.unlockDate.toLocaleDateString('en-US', { 
  month: 'short', 
  day: 'numeric', 
  year: 'numeric' 
});

const formatCurrency = (val: number) => 
  new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

const formatNumber = (val: number) => 
  new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 2 }).format(val);
---

<div class="unlock-card" style={`--shock-color: ${shock.color}`}>
  <div class="card-header">
    <div class="coin-info">
      <div class="coin-avatar">{unlock.symbol[0]}</div>
      <div>
        <h3 class="coin-name">{unlock.name}</h3>
        <span class="coin-ticker">{unlock.symbol}</span>
      </div>
    </div>
    <div class="shock-badge" title="Supply Shock Index">
      <span class="shock-dot"></span>
      {shock.label} SHOCK
    </div>
  </div>

  <div class="card-body">
    <div class="stat-group">
      <span class="stat-label">Unlock Amount</span>
      <span class="stat-value">{formatNumber(unlock.amount)} {unlock.symbol}</span>
      <span class="stat-sub">{formatCurrency(unlock.amountUsd)}</span>
    </div>

    <div class="stat-group">
      <span class="stat-label">Market Impact</span>
      <span class="stat-value">{unlock.percentOfCirculating.toFixed(2)}%</span>
      <span class="stat-sub">of Circulating</span>
    </div>
  </div>

  <div class="shock-meter">
    <div class="meter-bar" style={`width: ${Math.min(unlock.percentOfCirculating * 10, 100)}%`}></div>
  </div>

  <div class="card-footer">
    <div class="event-meta">
      <span class="category-tag">{unlock.category}</span>
      <span class="type-tag">{unlock.isCliff ? 'Cliff' : 'Linear'}</span>
    </div>
    <div class="event-date">
      <span class="date-label">{isFuture ? 'Unlocks in' : 'Unlocked on'}</span>
      <span class="date-value">{dateStr}</span>
    </div>
  </div>
</div>

<style>
  .unlock-card {
    background: linear-gradient(145deg, oklch(17% 0.04 260 / 0.8), oklch(12% 0.03 260 / 0.6));
    border: 1px solid oklch(25% 0.05 195 / 0.4);
    border-radius: 1.25rem;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .unlock-card:hover {
    transform: translateY(-4px) scale(1.01);
    border-color: var(--shock-color);
    box-shadow: 0 10px 30px -10px var(--shock-color);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .coin-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .coin-avatar {
    width: 40px;
    height: 40px;
    background: var(--shock-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: black;
    box-shadow: 0 0 15px var(--shock-color);
  }

  .coin-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    color: white;
  }

  .coin-ticker {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.1em;
  }

  .shock-badge {
    font-size: 0.625rem;
    font-weight: 900;
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
    background: color-mix(in oklch, var(--shock-color) 15%, transparent);
    color: var(--shock-color);
    border: 1px solid color-mix(in oklch, var(--shock-color) 30%, transparent);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    letter-spacing: 0.05em;
  }

  .shock-dot {
    width: 6px;
    height: 6px;
    background: var(--shock-color);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--shock-color);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { opacity: 0.4; }
    50% { opacity: 1; }
    100% { opacity: 0.4; }
  }

  .card-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .stat-group {
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
  }

  .stat-sub {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .shock-meter {
    height: 4px;
    background: oklch(25% 0.05 195 / 0.3);
    border-radius: 2px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .meter-bar {
    height: 100%;
    background: var(--shock-color);
    box-shadow: 0 0 10px var(--shock-color);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
    border-top: 1px solid oklch(25% 0.05 195 / 0.2);
  }

  .event-meta {
    display: flex;
    gap: 0.5rem;
  }

  .category-tag, .type-tag {
    font-size: 0.625rem;
    padding: 0.25rem 0.625rem;
    border-radius: 0.5rem;
    background: oklch(20% 0.04 260);
    color: var(--color-text-secondary);
    border: 1px solid oklch(30% 0.05 195 / 0.3);
  }

  .event-date {
    text-align: right;
  }

  .date-label {
    display: block;
    font-size: 0.625rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.125rem;
  }

  .date-value {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-400);
  }
</style>
