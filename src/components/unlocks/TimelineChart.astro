---
/**
 * Lightweight SVG Timeline Chart for Token Unlocks
 * Phase 1B: Visual Semantic System
 */

interface Unlock {
  date: string;
  amount: number;
  category: string;
}

interface Props {
  unlocks: Unlock[];
  symbol: string;
  color?: string;
}

const { unlocks, symbol, color = '#00f3ff' } = Astro.props;

// Process data for the chart
const sorted = [...unlocks].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
const maxAmount = Math.max(...sorted.map(u => u.amount));

// Chart Dimensions
const width = 800;
const height = 200;
const padding = 40;
const chartWidth = width - padding * 2;
const chartHeight = height - padding * 2;

// Calculate points
const points = sorted.map((u, i) => {
  const x = padding + (i / (sorted.length - 1 || 1)) * chartWidth;
  const y = height - padding - (u.amount / maxAmount) * chartHeight;
  return { x, y, date: u.date, amount: u.amount, category: u.category };
});

// Path for the area
const areaPath = `M ${points[0].x},${height - padding} ` + 
  points.map(p => `L ${p.x},${p.y}`).join(' ') + 
  ` L ${points[points.length - 1].x},${height - padding} Z`;

const linePath = points.map((p, i) => (i === 0 ? `M ${p.x},${p.y}` : `L ${p.x},${p.y}`)).join(' ');

const formatDateShort = (d: string) => {
  const date = new Date(d);
  return `${date.getMonth() + 1}/${date.getFullYear().toString().slice(-2)}`;
};
---

<div class="timeline-chart-container">
  <svg viewBox={`0 0 ${width} ${height}`} class="timeline-svg" preserveAspectRatio="xMidYMid meet">
    <!-- Grid Lines -->
    <line x1={padding} y1={height - padding} x2={width - padding} y2={height - padding} stroke="rgba(255,255,255,0.1)" stroke-width="1" />
    
    <!-- Area Gradient -->
    <defs>
      <linearGradient id="areaGradient" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color={color} stop-opacity="0.3" />
        <stop offset="100%" stop-color={color} stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- Area -->
    <path d={areaPath} fill="url(#areaGradient)" />

    <!-- Line -->
    <path d={linePath} fill="none" stroke={color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />

    <!-- Data Points -->
    {points.map((p, i) => (
      <g class="chart-point-group">
        <circle cx={p.x} cy={p.y} r="4" fill={color} />
        <circle cx={p.x} cy={p.y} r="8" fill={color} fill-opacity="0.2" class="pulse-ring" />
        
        <!-- Label -->
        <text x={p.x} y={height - padding + 20} text-anchor="middle" class="axis-label">
          {formatDateShort(p.date)}
        </text>

        <!-- Tooltip (CSS Based) -->
        <g class="tooltip">
          <rect x={p.x - 50} y={p.y - 45} width="100" height="35" rx="4" fill="rgba(0,0,0,0.8)" />
          <text x={p.x} y={p.y - 32} text-anchor="middle" fill="white" font-size="10" font-weight="bold">
            {new Intl.NumberFormat('en-US', { notation: 'compact' }).format(p.amount)} {symbol}
          </text>
          <text x={p.x} y={p.y - 18} text-anchor="middle" fill={color} font-size="8" font-weight="bold" text-transform="uppercase">
            {p.category}
          </text>
        </g>
      </g>
    ))}
  </svg>
</div>

<style>
  .timeline-chart-container {
    width: 100%;
    background: oklch(10% 0.02 260);
    border-radius: 1rem;
    padding: 1rem;
    border: 1px solid oklch(25% 0.05 195 / 0.2);
    overflow: hidden;
  }

  .timeline-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .axis-label {
    font-size: 10px;
    fill: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .chart-point-group {
    cursor: pointer;
  }

  .tooltip {
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .chart-point-group:hover .tooltip {
    opacity: 1;
  }

  .chart-point-group:hover circle {
    r: 6;
    stroke: white;
    stroke-width: 2;
  }

  .pulse-ring {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { r: 6; opacity: 0.5; }
    100% { r: 15; opacity: 0; }
  }
</style>
