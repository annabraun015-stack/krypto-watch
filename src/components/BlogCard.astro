---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { type Locale } from '../i18n';

interface Props {
  post: CollectionEntry<'blog'>;
  locale: Locale;
}

const { post, locale } = Astro.props;
const { title, description, date, author, category, tags, image, imageAlt, readingTime, featured, coinSymbols } = post.data;

// Build slug URL based on locale and directory
const slugPath = post.id.replace(/^(de|en)\//, '').replace(/\.mdx?$/, '');
const postUrl = locale === 'de' ? `/blog/${slugPath}/` : `/en/blog/${slugPath}/`;

const formattedDate = new Intl.DateTimeFormat(locale === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(new Date(date));

const categoryColors: Record<string, string> = {
  bitcoin: 'badge-bitcoin',
  ethereum: 'badge-eth',
  defi: 'badge-defi',
  regulation: 'badge-default',
  nfts: 'badge-purple',
  altcoins: 'badge-pink',
};
const catClass = categoryColors[category] ?? 'badge-default';
---

<article class={`blog-card ${featured ? 'blog-card--featured' : ''}`} aria-label={title}>
  <!-- Image -->
  <a href={postUrl} class="blog-card-image-wrap" tabindex="-1" aria-hidden="true">
    {image ? (
      <Image
        src={image}
        alt={imageAlt ?? title}
        class="blog-card-image"
        loading="lazy"
        decoding="async"
        width={600}
        height={340}
      />
    ) : (
      <div class="blog-card-image-placeholder" aria-hidden="true">
        <span class="placeholder-coin">
          {category === 'bitcoin' ? '₿' : category === 'ethereum' ? 'Ξ' : '🪙'}
        </span>
      </div>
    )}
    {featured && (
      <div class="featured-badge" aria-label="Featured">⭐ Featured</div>
    )}
    {coinSymbols?.length > 0 && (
      <div class="coin-chips" aria-label={`Coins: ${coinSymbols.join(', ')}`}>
        {coinSymbols.map((s) => (
          <span class="coin-chip">{s}</span>
        ))}
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="blog-card-body">
    <!-- Category + reading time -->
    <div class="blog-card-meta">
      <span class={`badge ${catClass}`}>{category}</span>
      {readingTime && (
        <span class="reading-time">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm0 2a6 6 0 1 0 0 12A6 6 0 0 0 8 2zm0 2a.75.75 0 0 1 .75.75v3.5l2.25 1.3a.75.75 0 1 1-.75 1.299l-2.625-1.5A.75.75 0 0 1 7.25 8.75v-4A.75.75 0 0 1 8 4z"/>
          </svg>
          {readingTime} {locale === 'de' ? 'Min.' : 'min'}
        </span>
      )}
    </div>

    <!-- Title -->
    <h2 class="blog-card-title">
      <a href={postUrl} class="blog-card-title-link">{title}</a>
    </h2>

    <!-- Description -->
    <p class="blog-card-desc">{description}</p>

    <!-- Footer: author + date -->
    <footer class="blog-card-footer">
      <div class="blog-card-author">
        <div class="author-avatar" aria-hidden="true">{author.charAt(0).toUpperCase()}</div>
        <div>
          <div class="author-name">{author}</div>
          <time class="post-date" datetime={new Date(date).toISOString()}>{formattedDate}</time>
        </div>
      </div>
      <a href={postUrl} class="read-more-link" aria-label={`${locale === 'de' ? 'Weiterlesen' : 'Read more'}: ${title}`}>
        {locale === 'de' ? 'Weiterlesen' : 'Read more'}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
        </svg>
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-card {
    background: linear-gradient(135deg, oklch(17% 0.04 260 / 0.7), oklch(12% 0.03 260 / 0.5));
    border: 1px solid oklch(25% 0.05 195 / 0.4);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    height: 100%;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-brand-400);
    box-shadow: 0 12px 40px -8px oklch(8% 0.05 260 / 0.6), var(--shadow-neon-cyan);
  }

  .blog-card--featured {
    border-color: var(--color-accent-500);
    box-shadow: 0 0 20px -5px var(--color-accent-500);
  }

  /* Image */
  .blog-card-image-wrap {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: oklch(14% 0.04 250);
  }

  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .blog-card:hover .blog-card-image { transform: scale(1.05); }

  .blog-card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, oklch(15% 0.05 250), oklch(20% 0.08 260));
  }

  .placeholder-coin {
    font-size: 3.5rem;
    opacity: 0.4;
    filter: blur(0.5px);
  }

  .featured-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-neon-purple);
    color: black;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
    box-shadow: var(--shadow-neon-purple);
  }

  .coin-chips {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    gap: 0.25rem;
  }

  .coin-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: oklch(8% 0.03 250 / 0.8);
    color: var(--color-brand-300);
    border: 1px solid oklch(45% 0.2 250 / 0.3);
    backdrop-filter: blur(4px);
  }

  /* Body */
  .blog-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }

  /* Meta */
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .reading-time {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Badge variants */
  .badge-bitcoin { background: oklch(75% 0.18 60 / 0.12); color: var(--color-bitcoin); border-color: oklch(75% 0.18 60 / 0.25); }
  .badge-eth { background: oklch(68% 0.14 280 / 0.12); color: oklch(75% 0.18 280); border-color: oklch(68% 0.14 280 / 0.25); }
  .badge-defi { background: oklch(72% 0.2 165 / 0.12); color: var(--color-defi); border-color: oklch(72% 0.2 165 / 0.25); }
  .badge-purple { background: oklch(65% 0.2 300 / 0.12); color: oklch(72% 0.2 300); border-color: oklch(65% 0.2 300 / 0.25); }
  .badge-pink { background: oklch(68% 0.22 0 / 0.12); color: oklch(75% 0.22 0); border-color: oklch(68% 0.22 0 / 0.25); }
  .badge-default { background: oklch(35% 0.05 195 / 0.3); color: var(--color-text-secondary); border-color: oklch(35% 0.05 195 / 0.3); }

  /* Title */
  .blog-card-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    flex: 1;
  }

  .blog-card-title-link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-card-title-link:hover { color: var(--color-brand-300); }

  /* Description */
  .blog-card-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer */
  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid oklch(25% 0.05 250 / 0.3);
    margin-top: auto;
    gap: 0.75rem;
  }

  .blog-card-author { display: flex; align-items: center; gap: 0.625rem; min-width: 0; }

  .author-avatar {
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-neon-cyan), var(--color-neon-purple));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .read-more-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-400);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s, gap 0.2s;
    flex-shrink: 0;
  }

  .read-more-link:hover { color: var(--color-brand-300); gap: 0.5rem; }
</style>
