---
import type { CollectionEntry } from 'astro:content';
import { type Locale } from '../../i18n';

interface Props {
  posts: CollectionEntry<'blog'>[];
  locale: Locale;
}

const { posts, locale } = Astro.props;

// Border colors for the 4 slots
const borderColors = [
  'var(--color-neon-cyan)',
  'var(--color-accent-500)',
  'var(--color-neon-purple)',
  'var(--color-brand-400)'
];

// Helper to get localized reading time
const getReadingTime = (time: number) => {
  return locale === 'de' ? `${time} Min.` : `${time} min read`;
};
---

<section class="featured-strip" aria-label="Featured Stories">
  <div class="container">
    <div class="featured-grid">
      {posts.map((post, index) => {
        const { title, image, imageAlt, readingTime, category, status } = post.data;
        const slugPath = post.id.replace(/^(de|en)\//, '').replace(/\.mdx?$/, '');
        const postUrl = locale === 'de' ? `/blog/${slugPath}/` : `/en/blog/${slugPath}/`;
        const borderColor = borderColors[index % borderColors.length];

        return (
          <article 
            class="featured-item" 
            style={`--strip-border: ${borderColor}`}
            data-status={status}
          >
            <a href={postUrl} class="item-link">
              <div class="image-container">
                {image ? (
                  <img src={image} alt={imageAlt ?? title} class="item-image" loading="lazy" />
                ) : (
                  <div class="item-image-placeholder"></div>
                )}
                
                <!-- Top-Right Badge (Category) -->
                <div class="badge-top-right">
                  <span class="category-tag">{category}</span>
                </div>

                <!-- Bottom-Left Badge (Reading Time) -->
                <div class="badge-bottom-left">
                  {readingTime && <span class="read-tag">{getReadingTime(readingTime)}</span>}
                </div>

                <!-- Bottom-Right Badge (Status) -->
                <div class="badge-bottom-right">
                   {status && <span class="status-tag">{status}</span>}
                </div>
              </div>
              
              <div class="content-container">
                <h3 class="item-title">{title}</h3>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .featured-strip {
    padding-block: 2rem;
    background: var(--color-surface-950);
    position: relative;
    z-index: 20;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .featured-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .featured-item {
    position: relative;
    border: 1px solid oklch(25% 0.05 250 / 0.5);
    border-top: 3px solid var(--strip-border);
    background: linear-gradient(
      180deg, 
      oklch(15% 0.04 250 / 0.9) 0%, 
      oklch(10% 0.03 250 / 0.7) 100%
    );
    border-radius: 4px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 1, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .featured-item:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: 
      0 20px 40px -15px rgba(0, 0, 0, 0.8),
      0 0 20px -5px var(--strip-border);
    border-color: color-mix(in oklch, var(--strip-border) 40%, transparent);
  }

  .item-link {
    text-decoration: none;
    display: block;
    height: 100%;
  }

  .image-container {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-900);
  }

  .item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .featured-item:hover .item-image {
    transform: scale(1.05);
  }

  /* Badges */
  .badge-top-right {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
  }

  .category-tag {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.75);
    color: white;
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    letter-spacing: 0.05em;
  }

  .badge-bottom-left {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
  }

  .read-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .badge-bottom-right {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
  }

  .status-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-primary);
  }

  /* Specific colors for status */
  .featured-item[data-status="LIVE"] .status-tag { color: #ff3e3e; }
  .featured-item[data-status="TRENDING"] .status-tag { color: var(--color-neon-purple); }
  .featured-item[data-status="UPDATED"] .status-tag { color: var(--color-neon-cyan); }
  .featured-item[data-status="ANALYSIS"] .status-tag { color: var(--color-text-muted); }

  .content-container {
    padding: 1.25rem 1rem;
  }

  .item-title {
    font-family: var(--font-sans); /* Matching the image's clean look */
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-item:hover .item-title {
    color: var(--strip-border);
  }
</style>
