---
import type { CollectionEntry } from 'astro:content';

interface Props {
  alerts?: { time: string; text: string }[];
  title: string;
  posts?: CollectionEntry<'blog'>[];
  locale?: string;
}

const { alerts, title, posts, locale = 'de' } = Astro.props;

const items = posts 
  ? posts.map(p => ({
      time: new Intl.DateTimeFormat(locale === 'de' ? 'de-DE' : 'en-US', { hour: '2-digit', minute: '2-digit' }).format(new Date(p.data.date)) + ' UTC',
      text: p.data.title,
      href: locale === 'de' ? `/blog/${p.id.replace(/^de\//, '').replace(/\.mdx?$/, '')}/` : `/en/blog/${p.id.replace(/^en\//, '').replace(/\.mdx?$/, '')}/`
    }))
  : alerts?.map(a => ({ ...a, href: '#' }));
---

<div class="trending-alerts">
  <div class="sidebar-header">
    <div class="decor-bar"></div>
    <h2 class="sidebar-title">{title}</h2>
  </div>

  <div class="alerts-list">
    {items?.map((item) => (
      <a href={item.href} class="alert-card card-glass">
        <div class="alert-time">{item.time}</div>
        <p class="alert-text">{item.text}</p>
        <div class="alert-indicator"></div>
      </a>
    ))}
  </div>
</div>

<style>
  .trending-alerts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .decor-bar {
    width: 4px;
    height: 1.5rem;
    background: var(--color-neon-cyan);
    box-shadow: var(--shadow-neon-cyan);
  }

  .sidebar-title {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-neon-purple);
    text-transform: uppercase;
  }

  .alerts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .alert-card {
    display: block;
    text-decoration: none;
    padding: 1.25rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .alert-card:hover {
    transform: translateX(4px);
    border-color: var(--color-neon-cyan);
  }

  .alert-card:hover .alert-indicator {
    opacity: 1;
  }

  .alert-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-neon-cyan);
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .alert-text {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .alert-indicator {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-neon-cyan);
    box-shadow: var(--shadow-neon-cyan);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
</style>
