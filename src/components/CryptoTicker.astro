---
// Static crypto ticker – Euro-based structure
const coins = [
  { symbol: 'BTC', name: 'Bitcoin', price: '€91.140', change: '+2.4%', pos: true },
  { symbol: 'ETH', name: 'Ethereum', price: '€2.980', change: '+1.8%', pos: true },
  { symbol: 'SOL', name: 'Solana', price: '€168', change: '-0.7%', pos: false },
  { symbol: 'BNB', name: 'BNB', price: '€381', change: '+0.9%', pos: true },
  { symbol: 'XRP', name: 'XRP', price: '€0,57', change: '+3.2%', pos: true },
  { symbol: 'ADA', name: 'Cardano', price: '€0,44', change: '-1.1%', pos: false },
  { symbol: 'AVAX', name: 'Avalanche', price: '€35', change: '+4.6%', pos: true },
  { symbol: 'LINK', name: 'Chainlink', price: '€13,1', change: '+2.1%', pos: true },
];

// Doubled for seamless loop
const allCoins = [...coins, ...coins];
---

<div class="ticker-wrap" role="region" aria-label="Crypto Marktpreise" aria-live="polite">
  <div class="ticker-inner" aria-hidden="true">
    {allCoins.map((coin) => (
      <div class="ticker-item" data-symbol={coin.symbol}>
        <span class="ticker-symbol">{coin.symbol}</span>
        <span class="ticker-price" data-price>{coin.price}</span>
        <span class={`ticker-change ${coin.pos ? 'pos' : 'neg'}`} data-change>{coin.change}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .ticker-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ticker-symbol {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--color-brand-400);
    letter-spacing: 0.05em;
  }

  .ticker-price {
    font-size: 0.8125rem;
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s ease;
  }

  .ticker-price.up { color: oklch(72% 0.2 145); }
  .ticker-price.down { color: oklch(65% 0.25 25); }

  .ticker-change {
    font-size: 0.75rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    background: color-mix(in oklch, currentColor 10%, transparent);
  }

  .ticker-change.pos { color: oklch(72% 0.2 145); }
  .ticker-change.neg { color: oklch(65% 0.25 25); }
</style>

<script>
  const symbols = ['BTCEUR', 'ETHEUR', 'SOLEUR', 'BNBEUR', 'XRPEUR', 'ADAEUR', 'AVAXEUR', 'LINKEUR'];
  const symbolMap: Record<string, string> = {
    'BTCEUR': 'BTC',
    'ETHEUR': 'ETH',
    'SOLEUR': 'SOL',
    'BNBEUR': 'BNB',
    'XRPEUR': 'XRP',
    'ADAEUR': 'ADA',
    'AVAXEUR': 'AVAX',
    'LINKEUR': 'LINK'
  };

  function formatPrice(price: string, symbol: string) {
    const num = parseFloat(price);
    // Use German locale for Euro formatting (€ 1.234,56)
    const formatted = num.toLocaleString('de-DE', {
      minimumFractionDigits: num > 100 ? 0 : (num > 1 ? 2 : 4),
      maximumFractionDigits: num > 100 ? 0 : (num > 1 ? 2 : 4),
    });
    return '€' + formatted;
  }

  function initTicker() {
    const ws = new WebSocket('wss://stream.binance.com:9443/ws/!miniTicker@arr');

    ws.onmessage = (event) => {
      const data = JSON.parse(event.data);
      data.forEach((ticker: any) => {
        if (symbols.includes(ticker.s)) {
          const symbol = symbolMap[ticker.s];
          const price = ticker.c;
          const open = ticker.o;
          const changePercent = ((parseFloat(price) - parseFloat(open)) / parseFloat(open) * 100).toFixed(2);
          const isPos = parseFloat(changePercent) >= 0;

          const elements = document.querySelectorAll(`[data-symbol="${symbol}"]`);
          elements.forEach(el => {
            const priceEl = el.querySelector('[data-price]');
            const changeEl = el.querySelector('[data-change]');

            if (priceEl) {
              const oldPrice = priceEl.textContent;
              const newPriceFormatted = formatPrice(price, symbol);
              
              if (oldPrice !== newPriceFormatted) {
                priceEl.textContent = newPriceFormatted;
                
                // Compare numeric values for direction
                const currentPrice = parseFloat(price);
                // Extract number from localized string (replace dot and comma)
                const previousPriceText = oldPrice?.replace('€', '').replace(/\./g, '').replace(',', '.') || '0';
                const previousPrice = parseFloat(previousPriceText);
                
                if (currentPrice > previousPrice) {
                  priceEl.classList.add('up');
                  setTimeout(() => priceEl.classList.remove('up'), 500);
                } else if (currentPrice < previousPrice) {
                  priceEl.classList.add('down');
                  setTimeout(() => priceEl.classList.remove('down'), 500);
                }
              }
            }

            if (changeEl) {
              // Percentage change usually keeps dot in technical contexts, but we can localize it too
              const changeFormatted = parseFloat(changePercent).toLocaleString('de-DE', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
                signDisplay: 'always'
              }) + '%';
              
              changeEl.textContent = changeFormatted;
              changeEl.classList.toggle('pos', isPos);
              changeEl.classList.toggle('neg', !isPos);
            }
          });
        }
      });
    };

    ws.onclose = () => {
      setTimeout(initTicker, 5000);
    };
  }

  // Initialize after page load
  document.addEventListener('astro:page-load', initTicker);
  if (document.readyState === 'complete') {
    initTicker();
  } else {
    window.addEventListener('load', initTicker);
  }
</script>
