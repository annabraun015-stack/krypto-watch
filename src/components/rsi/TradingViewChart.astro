---
interface Props {
  symbol: string;
}

const { symbol } = Astro.props;

// Prepare the symbol for TradingView (e.g., BINANCE:BTCUSDT)
const tvSymbol = symbol.toUpperCase().includes('USDT') ? symbol : `BINANCE:${symbol.toUpperCase()}USDT`;
const containerId = `tv-chart-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="tradingview-widget-container">
  <div id={containerId} class="tv-chart-widget"></div>
  <script is:inline src="https://s3.tradingview.com/tv.js"></script>
  <script is:inline define:vars={{ tvSymbol, containerId }}>
    function initChart() {
      if (typeof TradingView !== 'undefined') {
        new TradingView.widget({
          "width": "100%",
          "height": 500,
          "symbol": tvSymbol,
          "interval": "240",
          "timezone": "Etc/UTC",
          "theme": "dark",
          "style": "1",
          "locale": "en",
          "toolbar_bg": "#f1f3f6",
          "enable_publishing": false,
          "hide_side_toolbar": false,
          "allow_symbol_change": true,
          "container_id": containerId,
          "studies": [
            "RSI@tv-basicstudies"
          ],
        });
      }
    }

    if (document.readyState === 'complete') {
      initChart();
    } else {
      window.addEventListener('load', initChart);
    }
  </script>
</div>

<style>
  .tradingview-widget-container {
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid oklch(25% 0.05 250 / 0.3);
    background: oklch(10% 0.02 250);
  }
</style>
