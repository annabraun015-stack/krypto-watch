---
interface Props {
  symbol: string;
}

const { symbol } = Astro.props;
const tvSymbol = symbol.toUpperCase().includes('USDT') ? symbol : `BINANCE:${symbol.toUpperCase()}USDT`;
const widgetId = `tv-gauge-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="rsi-gauge-card">
  <div class="tradingview-widget-container">
    <div id={widgetId} class="tv-widget-container"></div>
  </div>
</div>

<style>
  .rsi-gauge-card {
    background: oklch(14% 0.04 250 / 0.5);
    border: 1px solid oklch(25% 0.05 250 / 0.35);
    border-radius: 1rem;
    padding: 1.5rem;
    min-height: 450px;
  }
</style>

<script is:inline define:vars={{ tvSymbol, widgetId }}>
  function loadWidget() {
    const container = document.getElementById(widgetId);
    if (!container) return;

    const script = document.createElement('script');
    script.type = 'text/javascript';
    script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-technical-analysis.js';
    script.async = true;
    script.innerHTML = JSON.stringify({
      "interval": "4h",
      "width": "100%",
      "isTransparent": true,
      "height": "450",
      "symbol": tvSymbol,
      "showIntervalTabs": true,
      "displayMode": "single",
      "locale": "en",
      "colorTheme": "dark",
      "isTransparent": false
    });
    container.appendChild(script);
  }

  // Load immediately or on next tick
  if (document.readyState === 'complete') {
    loadWidget();
  } else {
    window.addEventListener('load', loadWidget);
  }
</script>
