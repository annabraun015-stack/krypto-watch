---
interface Props {
  symbol: string;
}

const { symbol } = Astro.props;
const tvSymbol = symbol.toUpperCase().includes('USDT') ? symbol : `BINANCE:${symbol.toUpperCase()}USDT`;

const timeframes = [
  { label: '5m', interval: '5m' },
  { label: '15m', interval: '15m' },
  { label: '1h', interval: '1h' },
  { label: '4h', interval: '4h' },
  { label: '1D', interval: '1D' },
  { label: '1W', interval: '1W' },
];
---

<div class="timeframe-grid">
  {timeframes.map((tf, index) => (
    <div class="tf-card" id={`tf-card-${index}`}>
      <div class="tf-label">{tf.label}</div>
      <div class="tf-widget-container" id={`tf-widget-${index}`}></div>
    </div>
  ))}
</div>

<style>
  .timeframe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 640px) {
    .timeframe-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .timeframe-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .tf-card {
    background: oklch(14% 0.04 250 / 0.5);
    border: 1px solid oklch(25% 0.05 250 / 0.35);
    border-radius: 1rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  .tf-card:hover {
    border-color: var(--color-brand-500);
    transform: translateY(-2px);
    box-shadow: 0 0 15px oklch(65% 0.2 250 / 0.1);
  }

  .tf-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brand-400);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tf-widget-container {
    width: 100%;
    height: 120px; /* Mini gauge height */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Scanline effect for cards */
  .tf-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.02));
    background-size: 100% 2px, 3px 100%;
    pointer-events: none;
    opacity: 0.3;
  }
</style>

<script is:inline define:vars={{ tvSymbol, timeframes }}>
  function loadTimeframeWidgets() {
    timeframes.forEach((tf, index) => {
      const container = document.getElementById(`tf-widget-${index}`);
      if (!container) return;

      const script = document.createElement('script');
      script.type = 'text/javascript';
      script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-technical-analysis.js';
      script.async = true;
      script.innerHTML = JSON.stringify({
        "interval": tf.interval,
        "width": "100%",
        "isTransparent": true,
        "height": "140",
        "symbol": tvSymbol,
        "showIntervalTabs": false,
        "displayMode": "single",
        "locale": "en",
        "colorTheme": "dark"
      });
      container.appendChild(script);
    });
  }

  if (document.readyState === 'complete') {
    loadTimeframeWidgets();
  } else {
    window.addEventListener('load', loadTimeframeWidgets);
  }
</script>
