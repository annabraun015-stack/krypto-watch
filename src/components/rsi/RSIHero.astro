---
interface Props {
  symbol: string;
  locale: 'de' | 'en';
}

const { symbol, locale } = Astro.props;
const tvSymbol = symbol.toUpperCase().includes('USDT') ? symbol : `BINANCE:${symbol.toUpperCase()}USDT`;
const coinName = symbol.toUpperCase();

const statusLabel = locale === 'de' ? 'RSI STATUS' : 'RSI STATUS';
const analysisLabel = locale === 'de' ? 'TECHNISCHE ANALYSE' : 'TECHNICAL ANALYSIS';
---

<div class="rsi-hero">
  <div class="hero-main">
    <div class="indicator-section">
      <div class="scanner-header">
        <div class="scanner-title">
          <span class="glitch-text" data-text={`${coinName} RSI SCANNER`}>{coinName} RSI SCANNER</span>
        </div>
        <div class="scanner-meta">
          <span class="meta-item">FREQ: 2.4GHz</span>
          <span class="meta-item">SIG: STABLE</span>
        </div>
      </div>
      
      <div class="indicator-grid">
        <div class="main-gauge-wrap">
          <div class="tradingview-widget-container" id="rsi-hero-gauge">
            <div class="tradingview-widget-container__widget"></div>
          </div>
        </div>
        
        <div class="stats-panel">
          <div class="stat-row">
            <span class="stat-label">OSCILLATOR</span>
            <span class="stat-value neon-cyan">ACTIVE</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">MOMENTUM</span>
            <span class="stat-value neon-purple">TRACKING</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">VOLATILITY</span>
            <span class="stat-value">HIGH</span>
          </div>
          <div class="scan-line-v2"></div>
          <div class="live-status">
            <div class="pulse-dot"></div>
            <span class="status-text">SIGNAL: STABLE_RSI_LOCKED</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-sidebar">
      <div class="sidebar-top">
        <div class="label">{statusLabel}</div>
        <div class="value pulse-neon">NEUTRAL</div>
        <div class="status-glow"></div>
      </div>
      <div class="sidebar-bottom">
        <div class="info-bit">
          <span class="bit-label">RSI(14)</span>
          <span class="bit-value">54.21</span>
        </div>
        <div class="info-bit">
          <span class="bit-label">TREND</span>
          <span class="bit-value">SIDEWAYS</span>
        </div>
        <div class="data-stream">
          <div class="stream-bits">01010111 00110101 11010101</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .rsi-hero {
    margin-bottom: 4rem;
    position: relative;
  }

  /* Scanline effect */
  .rsi-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      transparent 0%,
      rgba(0, 255, 255, 0.05) 50%,
      transparent 100%
    );
    background-size: 100% 4px;
    pointer-events: none;
    z-index: 10;
    opacity: 0.1;
  }

  .hero-main {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    background: linear-gradient(135deg, oklch(12% 0.04 250 / 0.95), oklch(8% 0.02 250 / 0.8));
    border: 1px solid oklch(35% 0.1 250 / 0.4);
    border-radius: 2rem;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 50px -10px oklch(0% 0 0 / 0.8), 0 0 20px oklch(65% 0.2 250 / 0.05);
  }

  @media (min-width: 1024px) {
    .hero-main {
      grid-template-columns: 1fr 340px;
      padding: 2.5rem;
    }
  }

  .indicator-section {
    background: oklch(10% 0.03 250 / 0.6);
    border: 1px solid oklch(25% 0.05 250 / 0.5);
    border-radius: 1.5rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
  }

  .indicator-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand-400), transparent);
    animation: scan-horizontal 3s linear infinite;
  }

  @keyframes scan-horizontal {
    0% { transform: translateY(0); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(400px); opacity: 0; }
  }

  .scanner-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid oklch(25% 0.05 250 / 0.4);
    padding-bottom: 1rem;
  }

  .scanner-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    color: var(--color-text-primary);
    text-shadow: 0 0 20px oklch(65% 0.2 195 / 0.4);
  }

  .scanner-meta {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-brand-400);
  }

  .indicator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .indicator-grid {
      grid-template-columns: 1fr 220px;
    }
  }

  .main-gauge-wrap {
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, oklch(45% 0.2 195 / 0.1) 0%, transparent 70%);
  }

  .stats-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: oklch(12% 0.03 250 / 0.6);
    border: 1px solid oklch(35% 0.1 250 / 0.3);
    border-radius: 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .scan-line-v2 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(transparent, oklch(65% 0.2 195 / 0.1), transparent);
    transform: translateY(-100%);
    animation: scan-v2 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes scan-v2 {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(100%); }
    100% { transform: translateY(-100%); }
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .stat-label {
    color: var(--color-text-muted);
  }

  .stat-value {
    font-weight: 700;
  }

  .neon-cyan { color: oklch(75% 0.15 195); text-shadow: 0 0 12px oklch(75% 0.15 195 / 0.5); }
  .neon-purple { color: oklch(70% 0.2 300); text-shadow: 0 0 12px oklch(70% 0.2 300 / 0.5); }

  .live-status {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid oklch(25% 0.05 250 / 0.3);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: var(--color-brand-400);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-brand-400);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.6); opacity: 0.4; }
    100% { transform: scale(1); opacity: 1; }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 800;
    color: var(--color-brand-400);
    letter-spacing: 0.2em;
  }

  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-top {
    flex: 1;
    background: oklch(15% 0.05 250);
    border: 1px solid var(--color-brand-500);
    border-radius: 1.5rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .status-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, var(--color-brand-500 / 0.2) 0%, transparent 70%);
    animation: pulse-glow 2s infinite ease-in-out;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    margin-bottom: 1rem;
    color: var(--color-brand-400);
    position: relative;
    z-index: 2;
  }

  .value {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    color: white;
    text-shadow: 0 0 30px var(--color-brand-500);
    position: relative;
    z-index: 2;
  }

  .pulse-neon {
    animation: pulse-neon-v2 2s infinite ease-in-out;
  }

  @keyframes pulse-neon-v2 {
    0%, 100% { transform: scale(1); text-shadow: 0 0 20px var(--color-brand-500); }
    50% { transform: scale(1.05); text-shadow: 0 0 40px var(--color-brand-400); }
  }

  .sidebar-bottom {
    background: oklch(10% 0.03 250 / 0.7);
    border: 1px solid oklch(25% 0.05 250 / 0.4);
    border-radius: 1.5rem;
    padding: 1.75rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    position: relative;
  }

  .info-bit {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .bit-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
  }

  .bit-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-text-primary);
  }

  .data-stream {
    grid-column: span 2;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid oklch(25% 0.05 250 / 0.2);
  }

  .stream-bits {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--color-brand-400 / 0.4);
    letter-spacing: 0.3em;
    white-space: nowrap;
    overflow: hidden;
  }

  /* Glitch Effect */
  .glitch-text {
    position: relative;
    display: inline-block;
  }
  
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.8;
  }

  .glitch-text::before {
    color: #ff00ff;
    z-index: -1;
    animation: glitch 3s infinite;
  }

  .glitch-text::after {
    color: #00ffff;
    z-index: -2;
    animation: glitch 2s infinite reverse;
  }

  @keyframes glitch {
    0% { transform: translate(0); }
    20% { transform: translate(-2px, 2px); }
    40% { transform: translate(-2px, -2px); }
    60% { transform: translate(2px, 2px); }
    80% { transform: translate(2px, -2px); }
    100% { transform: translate(0); }
  }
</style>

<script is:inline define:vars={{ tvSymbol }}>
  // Technical Analysis widget loader for the hero
  const container = document.querySelector('#rsi-hero-gauge .tradingview-widget-container__widget');
  if (container) {
    const script = document.createElement('script');
    script.type = 'text/javascript';
    script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-technical-analysis.js';
    script.async = true;
    script.innerHTML = JSON.stringify({
      "interval": "1h",
      "width": "100%",
      "isTransparent": true,
      "height": "220",
      "symbol": tvSymbol,
      "showIntervalTabs": false,
      "displayMode": "single",
      "locale": "en",
      "colorTheme": "dark",
      "isTransparent": false
    });
    container.appendChild(script);
  }
</script>

