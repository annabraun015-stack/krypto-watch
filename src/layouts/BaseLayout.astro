---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig, navLinks } from '../config/site';
import { getLangAttribute, type Locale } from '../i18n';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  locale?: Locale;
  schema?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  altPath?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = siteConfig.ogImage,
  robots = 'index, follow',
  locale = 'de',
  schema,
  breadcrumbs,
  altPath,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteConfig.url).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteConfig.url).href;
const lang = getLangAttribute(locale);

// ── Global Organization Schema ──
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'KryptoWatch',
  url: siteConfig.url,
  logo: `${siteConfig.url}/logo.svg`,
  sameAs: [
    siteConfig.twitterHandle,
    siteConfig.telegram,
    siteConfig.linkedin,
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: siteConfig.email,
    contactType: 'editorial',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'KryptoWatch',
  url: siteConfig.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.url}/blog/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const navSchema = {
  '@context': 'https://schema.org',
  '@graph': navLinks[locale].map((link, idx) => ({
    '@type': 'SiteNavigationElement',
    '@id': `${siteConfig.url}${link.href}`,
    name: link.label,
    url: `${siteConfig.url}${link.href}`
  }))
};

const breadcrumbSchema = breadcrumbs
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((crumb, idx) => ({
        '@type': 'ListItem',
        position: idx + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    }
  : null;

const allSchemas = [
  orgSchema,
  websiteSchema,
  navSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---


<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Performance Hints -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Google tag (gtag.js) — loaded after consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      // Default to denied until consent given
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        wait_for_update: 500
      });
      // Load GA only if consent was previously given
      if (localStorage.getItem('kw_cookie_consent') === 'accepted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-BB2M5GPVTG';
        document.head.appendChild(s);
        gtag('config', 'G-BB2M5GPVTG');
      }
    </script>

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    {locale === 'de' ? (
      <>
        <link rel="alternate" hreflang="de" href={canonicalUrl} />
        <link rel="alternate" hreflang="en" href={altPath ? new URL(altPath, siteConfig.url).href : new URL(`/en${Astro.url.pathname}`, siteConfig.url).href} />
        <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
      </>
    ) : (
      <>
        <link rel="alternate" hreflang="en" href={canonicalUrl} />
        <link rel="alternate" hreflang="de" href={altPath ? new URL(altPath, siteConfig.url).href : new URL(Astro.url.pathname.replace(/^\/en/, '') || '/', siteConfig.url).href} />
        <link rel="alternate" hreflang="x-default" href={altPath ? new URL(altPath, siteConfig.url).href : new URL(Astro.url.pathname.replace(/^\/en/, '') || '/', siteConfig.url).href} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:site_name" content="KryptoWatch" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="7WNO-Kd4TiieZVfmSkANdCbUYcPtLlW5gAWcrVHCh3U" />

    <!-- Theme -->
    <meta name="theme-color" content={siteConfig.themeColor} />
    <meta name="color-scheme" content="dark" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Ensure font-display: swap for FOIT prevention -->
    <style is:inline>@font-face{font-display:swap}</style>

  </head>
  <body>
    <!-- Skip link -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header locale={locale} altPath={altPath} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer locale={locale} />

    <!-- GDPR Cookie Consent Banner -->
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-modal="false" aria-label="Cookie Einstellungen" style="display:none">
      <div class="cookie-banner-inner">
        <div class="cookie-banner-text">
          <strong>{locale === 'de' ? '🍪 Cookie-Einstellungen' : '🍪 Cookie Settings'}</strong>
          <p>{locale === 'de'
            ? 'Wir verwenden Analytics-Cookies, um unsere Website zu verbessern. Sie können Ihre Einwilligung jederzeit widerrufen.'
            : 'We use analytics cookies to improve our website. You can withdraw your consent at any time.'}
          </p>
        </div>
        <div class="cookie-banner-actions">
          <button id="cookie-reject" class="btn btn-ghost cookie-btn-reject">
            {locale === 'de' ? 'Ablehnen' : 'Reject'}
          </button>
          <button id="cookie-accept" class="btn btn-primary cookie-btn-accept">
            {locale === 'de' ? 'Akzeptieren' : 'Accept'}
          </button>
        </div>
      </div>
    </div>

    <style is:inline>
      .cookie-banner {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        width: min(calc(100vw - 2rem), 680px);
        background: oklch(14% 0.04 260);
        border: 1px solid oklch(35% 0.12 195 / 0.5);
        border-radius: 1rem;
        padding: 1.25rem 1.5rem;
        z-index: 9999;
        box-shadow: 0 8px 40px -4px oklch(5% 0.05 260 / 0.9);
        animation: slideUp 0.4s cubic-bezier(0.4,0,0.2,1);
      }
      @keyframes slideUp {
        from { opacity: 0; transform: translateX(-50%) translateY(20px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
      }
      .cookie-banner-inner {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .cookie-banner-text { flex: 1; min-width: 200px; }
      .cookie-banner-text strong { display: block; color: #fff; font-size: 0.9375rem; margin-bottom: 0.25rem; }
      .cookie-banner-text p { font-size: 0.8125rem; color: oklch(70% 0.05 195); margin: 0; line-height: 1.5; }
      .cookie-banner-actions { display: flex; gap: 0.75rem; flex-shrink: 0; }
      .cookie-btn-reject { font-size: 0.875rem; padding: 0.5rem 1rem; }
      .cookie-btn-accept { font-size: 0.875rem; padding: 0.5rem 1rem; }
    </style>

    <script is:inline>
      (function() {
        var consent = localStorage.getItem('kw_cookie_consent');
        if (!consent) {
          var banner = document.getElementById('cookie-banner');
          if (banner) banner.style.display = 'block';
        }
        var acceptBtn = document.getElementById('cookie-accept');
        var rejectBtn = document.getElementById('cookie-reject');
        if (acceptBtn) acceptBtn.addEventListener('click', function() {
          localStorage.setItem('kw_cookie_consent', 'accepted');
          document.getElementById('cookie-banner').style.display = 'none';
          // Load GA after accept
          if (typeof gtag === 'function') {
            gtag('consent', 'update', { analytics_storage: 'granted' });
          }
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-BB2M5GPVTG';
          document.head.appendChild(s);
        });
        if (rejectBtn) rejectBtn.addEventListener('click', function() {
          localStorage.setItem('kw_cookie_consent', 'rejected');
          document.getElementById('cookie-banner').style.display = 'none';
        });
      })();
    </script>
  </body>
</html>
