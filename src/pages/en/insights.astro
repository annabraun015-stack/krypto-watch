---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignalBadge from '../../components/onchain/SignalBadge.astro';
import { fetchPrices, fetchExchangeFlows } from '../../lib/onchain';
import { generateInsights } from '../../lib/insights';
import { buildLiveSignals } from '../../lib/signal-engine';

const prices = await fetchPrices();
const flows  = await fetchExchangeFlows(prices);
const { btcSignal, ethSignal } = buildLiveSignals(prices);
const btcFlow = flows.find(f => f.token === 'BTC')!;
const ethFlow = flows.find(f => f.token === 'ETH')!;

const insights = generateInsights({
  btcPrice: prices.btc, ethPrice: prices.eth,
  btcChange24h: prices.btcChange24h, ethChange24h: prices.ethChange24h,
  btcInflow: btcFlow.inflow24h, btcOutflow: btcFlow.outflow24h,
  ethInflow: ethFlow.inflow24h, ethOutflow: ethFlow.outflow24h,
  btcReserveChange7d: (Math.random() - 0.5) * 12,
  ethReserveChange7d: (Math.random() - 0.5) * 10,
  btcWhaleCount: Math.floor(Math.random() * 10 + 2),
  ethWhaleCount: Math.floor(Math.random() * 15 + 3),
  btcWhaleVolume: btcFlow.inflow24h * (0.3 + Math.random() * 0.4),
  ethWhaleVolume: ethFlow.inflow24h * (0.2 + Math.random() * 0.3),
  btcSmartSignal: btcSignal.factors.find(f => f.name === 'Smart Money Activity')?.score ?? 0,
});

function timeAgo(ts: number) {
  const d = Math.floor(Date.now()/1000) - ts;
  if (d < 60) return d + 's ago';
  if (d < 3600) return Math.floor(d/60) + 'm ago';
  return Math.floor(d/3600) + 'h ago';
}

const catIcons: Record<string,string> = { flow:'⇄', whale:'🐋', reserve:'🏦', signal:'⚡', 'smart-money':'🧠', alert:'🔔' };
---

<BaseLayout
  title="AI On-Chain Insights — Real-Time Bitcoin & Ethereum Intelligence | KryptoWatch"
  description="Automated, data-backed on-chain insights for Bitcoin and Ethereum. Every statement is verified with concrete metrics — facts only, no marketing."
  canonical="https://kryptowatch.de/en/insights/"
  locale="en" altPath="/insights/"
  breadcrumbs={[{name:'Home',url:'https://kryptowatch.de/en/'},{name:'Insights',url:'https://kryptowatch.de/en/insights/'}]}
>
  <section class="ih">
    <div class="container">
      <div class="ib">💡 AI Intelligence Layer</div>
      <h1 class="it">On-Chain Insights Feed</h1>
      <p class="is">Fact-based market analysis generated from real-time blockchain data. Every statement includes the underlying metric. <strong>No marketing. Just data.</strong></p>
      <div class="ist">
        <div class="isc"><div class="isl">Insights Generated</div><div class="isv">{insights.length}</div></div>
        <div class="isc"><div class="isl">New Alerts</div><div class="isv warn">{insights.filter(i=>i.isNew).length}</div></div>
        <div class="isc"><div class="isl">BTC Signal</div><div class="isv"><SignalBadge signal={btcSignal.signal} size="sm" /></div></div>
        <div class="isc"><div class="isl">ETH Signal</div><div class="isv"><SignalBadge signal={ethSignal.signal} size="sm" /></div></div>
      </div>
    </div>
  </section>

  <section class="im">
    <div class="container">
      <div class="il">
        <div class="feed">
          <div class="fh">
            <h2 class="ft">Intelligence Feed</h2>
            <div class="ff">
              <button class="fb fb--active" data-cat="all">All</button>
              <button class="fb" data-cat="flow">Flows</button>
              <button class="fb" data-cat="whale">Whales</button>
              <button class="fb" data-cat="reserve">Reserves</button>
              <button class="fb" data-cat="smart-money">Smart Money</button>
            </div>
          </div>
          <div class="fi-list">
            {insights.map(insight => (
              <article class={`fi fi--${insight.severity} fi--cat-${insight.category}`} data-category={insight.category}>
                <div class="fih">
                  <div class="fim">
                    <span>{catIcons[insight.category]}</span>
                    <span class={`fitok ft--${insight.token.toLowerCase()}`}>{insight.token}</span>
                    {insight.isNew && <span class="fnew">NEW</span>}
                    {insight.signal && <SignalBadge signal={insight.signal} size="sm" />}
                  </div>
                  <time class="fit">{timeAgo(insight.timestamp)}</time>
                </div>
                <h3 class="fitle">{insight.title}</h3>
                <p class="fib">{insight.body}</p>
                <div class="fimet"><span>📊</span><code>{insight.metric}</code></div>
              </article>
            ))}
          </div>
        </div>

        <aside class="sb">
          <div class="sbc">
            <div class="sbt">Market Snapshot</div>
            <div class="snap"><span class="sn btc">₿ BTC</span><span>${prices.btc.toLocaleString()}</span><span class={prices.btcChange24h>=0?'pos':'neg'}>{prices.btcChange24h>=0?'▲':'▼'}{Math.abs(prices.btcChange24h).toFixed(2)}%</span></div>
            <div class="snap"><span class="sn eth">Ξ ETH</span><span>${prices.eth.toLocaleString()}</span><span class={prices.ethChange24h>=0?'pos':'neg'}>{prices.ethChange24h>=0?'▲':'▼'}{Math.abs(prices.ethChange24h).toFixed(2)}%</span></div>
          </div>
          <div class="sbc">
            <div class="sbt">Active Signals</div>
            <div class="ssb"><div><span class="btc">₿</span> Bitcoin</div><SignalBadge signal={btcSignal.signal} size="md" /><div class="ssbc">Confidence: {btcSignal.confidence}%</div></div>
            <div class="ssb"><div><span class="eth">Ξ</span> Ethereum</div><SignalBadge signal={ethSignal.signal} size="md" /><div class="ssbc">Confidence: {ethSignal.confidence}%</div></div>
          </div>
          <div class="sbc">
            <div class="sbt">Quick Links</div>
            <a href="/en/signals/" class="ql">⚡ Signal Engine</a>
            <a href="/en/alerts/" class="ql">🔔 Alert System</a>
            <a href="/en/bitcoin-whale-tracker/" class="ql">🐋 BTC Whale Tracker</a>
            <a href="/en/exchange-flows/" class="ql">⇄ Exchange Flows</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
const btns = document.querySelectorAll('.fb');
const items = document.querySelectorAll('.fi');
btns.forEach(b => b.addEventListener('click', () => {
  btns.forEach(x => x.classList.remove('fb--active'));
  b.classList.add('fb--active');
  const cat = b.getAttribute('data-cat');
  items.forEach(i => { (i as HTMLElement).style.display = (cat === 'all' || i.getAttribute('data-category') === cat) ? '' : 'none'; });
}));
</script>

<style>
.ih{padding:3.5rem 0 2rem;background:radial-gradient(ellipse 60% 50% at 50% -10%,oklch(53% 0.26 195/0.08) 0%,transparent 60%)}
.ib{display:inline-block;padding:.375rem .875rem;background:oklch(53% 0.26 195/0.12);border:1px solid oklch(53% 0.26 195/0.3);border-radius:100px;font-size:.75rem;font-weight:700;color:var(--color-brand-300);text-transform:uppercase;letter-spacing:.08em;margin-bottom:1.25rem}
.it{font-family:var(--font-display);font-size:clamp(1.875rem,5vw,3rem);font-weight:900;line-height:1.1;margin-bottom:1rem}
.is{font-size:1.0625rem;color:var(--color-text-secondary);max-width:640px;line-height:1.7;margin-bottom:2rem}
.ist{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:.875rem}
.isc{padding:1rem 1.25rem;background:oklch(14% 0.03 260/0.8);border:1px solid oklch(28% 0.05 250/0.4);border-radius:.875rem}
.isl{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:.35rem}
.isv{font-family:var(--font-display);font-size:1.375rem;font-weight:800;color:var(--color-text-primary)}.isv.warn{color:oklch(75% 0.18 60)}
.im{padding:2rem 0 4rem}
.il{display:grid;grid-template-columns:1fr 300px;gap:1.75rem;align-items:start}
@media(max-width:960px){.il{grid-template-columns:1fr}}
.fh{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.25rem}
.ft{font-family:var(--font-display);font-size:1.25rem;font-weight:700}
.ff{display:flex;flex-wrap:wrap;gap:.375rem}
.fb{padding:.25rem .75rem;border-radius:100px;font-size:.8125rem;font-weight:600;color:var(--color-text-muted);background:transparent;border:1px solid oklch(30% 0.05 250/0.4);cursor:pointer;transition:all .2s}
.fb:hover,.fb--active{color:var(--color-brand-300);background:oklch(53% 0.26 195/0.15);border-color:var(--color-brand-500)}
.fi-list{display:flex;flex-direction:column;gap:1rem}
.fi{padding:1.25rem 1.5rem;background:oklch(13% 0.03 260/0.8);border:1px solid oklch(28% 0.05 250/0.4);border-radius:1rem;transition:border-color .2s}
.fi:hover{border-color:oklch(45% 0.15 250/0.5)}
.fi--warning{border-left:3px solid oklch(75% 0.18 60)}.fi--critical{border-left:3px solid oklch(65% 0.25 25)}.fi--info{border-left:3px solid oklch(53% 0.26 195/0.5)}
.fih{display:flex;align-items:center;justify-content:space-between;margin-bottom:.625rem}
.fim{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.fitok{font-size:.7rem;font-weight:700;padding:.15rem .5rem;border-radius:100px}
.ft--btc{background:oklch(75% 0.18 60/0.15);color:oklch(75% 0.18 60);border:1px solid oklch(75% 0.18 60/0.3)}
.ft--eth{background:oklch(68% 0.14 280/0.15);color:oklch(68% 0.14 280);border:1px solid oklch(68% 0.14 280/0.3)}
.ft--market{background:oklch(53% 0.26 195/0.15);color:var(--color-brand-300);border:1px solid oklch(53% 0.26 195/0.3)}
.fnew{font-size:.6rem;font-weight:800;letter-spacing:.1em;background:oklch(75% 0.18 60/0.2);color:oklch(75% 0.18 60);border:1px solid oklch(75% 0.18 60/0.3);padding:.15rem .45rem;border-radius:100px;text-transform:uppercase;animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.fit{font-size:.75rem;color:var(--color-text-muted)}
.fitle{font-size:1rem;font-weight:700;margin-bottom:.5rem;line-height:1.4}
.fib{font-size:.875rem;color:var(--color-text-secondary);line-height:1.65;margin-bottom:.875rem}
.fimet{display:inline-flex;align-items:center;gap:.5rem;padding:.375rem .875rem;background:oklch(17% 0.04 260/0.6);border:1px solid oklch(30% 0.05 250/0.4);border-radius:.5rem}
.fimet code{font-family:var(--font-mono);font-size:.8125rem;color:var(--color-brand-300);background:none;padding:0}
.sb{display:flex;flex-direction:column;gap:1rem}
.sbc{padding:1.25rem;background:oklch(13% 0.03 260/0.8);border:1px solid oklch(28% 0.05 250/0.4);border-radius:1rem}
.sbt{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:.875rem}
.snap{display:flex;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid oklch(25% 0.05 250/0.3)}
.snap:last-child{border:none}
.sn{font-weight:700;font-size:.875rem}.btc{color:oklch(75% 0.18 60)}.eth{color:oklch(68% 0.14 280)}
.snap .pos{color:oklch(72% 0.2 145);font-size:.8125rem;font-weight:600}.snap .neg{color:oklch(65% 0.25 25);font-size:.8125rem;font-weight:600}
.ssb{padding:.875rem;border-radius:.75rem;border:1px solid oklch(28% 0.05 250/0.3);margin-bottom:.5rem}
.ssbc{font-size:.75rem;color:var(--color-text-muted);margin-top:.375rem}
.ql{display:block;padding:.5rem .75rem;border-radius:.5rem;font-size:.875rem;color:var(--color-text-secondary);text-decoration:none;transition:all .2s}
.ql:hover{background:oklch(17% 0.04 260);color:var(--color-text-primary)}
</style>
