---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site';

const dePosts = await getCollection('blog', (p) => !p.data.draft && p.data.locale === 'de');
const enPosts = await getCollection('blog', (p) => !p.data.draft && p.data.locale === 'en');

dePosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
enPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const staticPages = [
  { url: '/', label: 'Homepage (DE)', lang: 'de' },
  { url: '/en/', label: 'Homepage (EN)', lang: 'en' },
  { url: '/blog/', label: 'Blog (DE)', lang: 'de' },
  { url: '/en/blog/', label: 'Blog (EN)', lang: 'en' },
  { url: '/token-unlocks/', label: 'Token Unlocks (DE)', lang: 'de' },
  { url: '/en/token-unlocks/', label: 'Token Unlocks (EN)', lang: 'en' },
  { url: '/rsi/', label: 'RSI Analyzer (DE)', lang: 'de' },
  { url: '/en/rsi/', label: 'RSI Analyzer (EN)', lang: 'en' },
  { url: '/sentiment/', label: 'Market Sentiment (DE)', lang: 'de' },
  { url: '/en/sentiment/', label: 'Market Sentiment (EN)', lang: 'en' },
  { url: '/about-us/', label: 'About Us (DE)', lang: 'de' },
  { url: '/en/about-us/', label: 'About Us (EN)', lang: 'en' },
  { url: '/contact-us/', label: 'Contact (DE)', lang: 'de' },
  { url: '/en/contact-us/', label: 'Contact (EN)', lang: 'en' },
  { url: '/privacy/', label: 'Privacy (DE)', lang: 'de' },
  { url: '/en/privacy/', label: 'Privacy (EN)', lang: 'en' },
  { url: '/terms/', label: 'Terms (DE)', lang: 'de' },
  { url: '/en/terms/', label: 'Terms (EN)', lang: 'en' },
  { url: '/impressum/', label: 'Imprint (DE)', lang: 'de' },
  { url: '/en/impressum/', label: 'Imprint (EN)', lang: 'en' },
];
---

<BaseLayout
  title="Sitemap – All Pages & Articles | KryptoWatch"
  description="Complete sitemap and page directory for KryptoWatch – your crypto intelligence platform covering Bitcoin, Ethereum, DeFi, and on-chain analytics."
  locale="en"
  robots="index, follow"
>
  <section class="page-hero" aria-labelledby="pages-title">
    <div class="container">
      <h1 id="pages-title" class="page-hero-title">Site Structure</h1>
      <p class="page-hero-subtitle">Overview of all content</p>
    </div>
  </section>

  <section class="section">
    <div class="container sitemap-layout">

      <!-- Static pages -->
      <div class="sitemap-section">
        <h2 class="sitemap-heading">📄 Pages</h2>
        <ul class="sitemap-list" role="list">
          {staticPages.map((p) => (
            <li role="listitem">
              <a href={p.url} class="sitemap-link">
                <span class="lang-chip">{p.lang.toUpperCase()}</span>
                {p.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- EN Blog posts -->
      <div class="sitemap-section">
        <h2 class="sitemap-heading">📝 Blog Articles (English)</h2>
        <ul class="sitemap-list" role="list">
          {enPosts.map((post) => {
            const slug = post.id.replace(/^en\//, '').replace(/\.mdx?$/, '');
            const date = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(post.data.date));
            return (
              <li role="listitem">
                <a href={`/en/blog/${slug}/`} class="sitemap-link">
                  <span class="lang-chip">EN</span>
                  <span class="sitemap-post-title">{post.data.title}</span>
                  <span class="sitemap-date">{date}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- DE Blog posts -->
      <div class="sitemap-section">
        <h2 class="sitemap-heading">📝 Blog-Artikel (Deutsch)</h2>
        <ul class="sitemap-list" role="list">
          {dePosts.map((post) => {
            const slug = post.id.replace(/^de\//, '').replace(/\.mdx?$/, '');
            const date = new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(post.data.date));
            return (
              <li role="listitem">
                <a href={`/blog/${slug}/`} class="sitemap-link">
                  <span class="lang-chip">DE</span>
                  <span class="sitemap-post-title">{post.data.title}</span>
                  <span class="sitemap-date">{date}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding-block: 4rem 2rem; text-align: center; }
  .page-hero-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.5rem); font-weight: 900; color: var(--color-text-primary); margin-bottom: 0.75rem; }
  .page-hero-subtitle { color: var(--color-text-muted); }

  .sitemap-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .sitemap-layout { grid-template-columns: 1fr 1fr 1fr; } }

  .sitemap-heading { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 1.25rem; padding-bottom: 0.5rem; border-bottom: 1px solid oklch(25% 0.05 250 / 0.3); }

  .sitemap-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }

  .sitemap-link { display: flex; align-items: baseline; gap: 0.625rem; padding: 0.5rem 0.75rem; border-radius: 0.5rem; text-decoration: none; color: var(--color-text-secondary); font-size: 0.9rem; transition: all 0.2s; line-height: 1.4; }
  .sitemap-link:hover { background: oklch(17% 0.04 250 / 0.5); color: var(--color-brand-300); }

  .lang-chip { font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; padding: 0.1rem 0.35rem; border-radius: 3px; background: oklch(45% 0.2 250 / 0.12); color: var(--color-brand-400); flex-shrink: 0; }

  .sitemap-post-title { flex: 1; }
  .sitemap-date { font-size: 0.75rem; color: var(--color-text-muted); flex-shrink: 0; }
</style>
