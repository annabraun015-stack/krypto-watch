---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WhaleTable from '../../components/onchain/WhaleTable.astro';
import SignalBadge from '../../components/onchain/SignalBadge.astro';
import { fetchPrices, fetchBTCWhales, formatUsd } from '../../lib/onchain';

const prices = await fetchPrices();
const whales = await fetchBTCWhales(prices.btc);
const totalVolume = whales.reduce((s, w) => s + w.usdValue, 0);
const megaCount   = whales.filter(w => w.size === 'mega' || w.size === 'gigantic').length;
const inflowCount = whales.filter(w => w.label === 'exchange-inflow').length;
const signal = inflowCount > whales.length * 0.5 ? 'bearish' : inflowCount < whales.length * 0.3 ? 'bullish' : 'neutral';
---

<BaseLayout
  title="Bitcoin Whale Tracker — Track Large BTC Transactions Live | KryptoWatch"
  description="Track large Bitcoin transactions in real time from $100K+. Monitor exchange inflows, outflows, and mega whale movements with live market signals."
  canonical="https://kryptowatch.de/en/bitcoin-whale-tracker/"
  locale="en"
  altPath="/bitcoin-whale-tracker/"
  breadcrumbs={[{ name: 'Home', url: 'https://kryptowatch.de/en/' }, { name: 'Bitcoin Whale Tracker', url: 'https://kryptowatch.de/en/bitcoin-whale-tracker/' }]}
>
  <section class="wh-hero">
    <div class="container">
      <div class="live-badge"><span class="ldot"></span> Live On-Chain Data</div>
      <h1 class="wh-title"><span class="btc-icon">₿</span> Bitcoin Whale Tracker</h1>
      <p class="wh-sub">Transactions above $100K are automatically detected, classified, and labeled with a market signal. No noise — only <strong>actionable insights</strong>.</p>
      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-lbl">BTC Price</div>
          <div class="stat-val">{formatUsd(prices.btc)}</div>
          <div class={`stat-chg ${prices.btcChange24h >= 0 ? 'pos' : 'neg'}`}>{prices.btcChange24h >= 0 ? '▲' : '▼'} {Math.abs(prices.btcChange24h).toFixed(2)}%</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Whale Volume</div>
          <div class="stat-val">{formatUsd(totalVolume)}</div>
          <div class="stat-sm">{whales.length} transactions</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Mega Whales ($1M+)</div>
          <div class="stat-val accent">{megaCount}</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Market Signal</div>
          <div style="margin-top:0.5rem"><SignalBadge signal={signal} size="lg" /></div>
        </div>
      </div>
    </div>
  </section>

  <section class="wh-main">
    <div class="container">
      <h2 class="sec-title">Live Whale Transactions</h2>
      <p class="sec-sub">Exchange Inflow (bearish) · Exchange Outflow (bullish) · Wallet-to-Wallet</p>
      <WhaleTable chain="BTC" locale="en" />

      <div class="signal-box">
        <h3>🧠 Signal Logic</h3>
        <div class="sig-grid">
          <div class="sig-item bear"><strong>📉 Bearish</strong><p>High exchange inflow → coins moving to exchanges → potential sell pressure</p></div>
          <div class="sig-item bull"><strong>📈 Bullish</strong><p>High exchange outflow → coins leaving exchanges → accumulation signal</p></div>
          <div class="sig-item neut"><strong>➖ Neutral</strong><p>Balanced inflow/outflow — no strong directional signal</p></div>
        </div>
      </div>

      <div class="rel-links">
        <h3>More Analytics</h3>
        <div class="rl-grid">
          <a href="/en/ethereum-whale-tracker/" class="rl-card"><span>Ξ</span><div><strong>ETH Whale Tracker</strong><em>Large ETH transactions</em></div></a>
          <a href="/exchange-flows/" class="rl-card"><span>⇄</span><div><strong>Exchange Flows</strong><em>Inflow / Outflow</em></div></a>
          <a href="/smart-money/" class="rl-card"><span>🧠</span><div><strong>Smart Money</strong><em>Top wallets by ROI</em></div></a>
          <a href="/exchange-reserves/" class="rl-card"><span>🏦</span><div><strong>Exchange Reserves</strong><em>Historical holdings</em></div></a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.wh-hero{padding:3.5rem 0 2.5rem;background:radial-gradient(ellipse 70% 50% at 10% -5%,oklch(75% 0.18 60/0.08) 0%,transparent 55%)}
.live-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.375rem .875rem;background:oklch(75% 0.18 60/0.12);border:1px solid oklch(75% 0.18 60/0.3);border-radius:100px;font-size:.75rem;font-weight:700;color:oklch(75% 0.18 60);text-transform:uppercase;letter-spacing:.08em;margin-bottom:1.25rem}
.ldot{width:7px;height:7px;border-radius:50%;background:oklch(72% 0.2 145);box-shadow:0 0 6px oklch(72% 0.2 145);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.wh-title{font-family:var(--font-display);font-size:clamp(1.875rem,5vw,3rem);font-weight:900;line-height:1.1;margin-bottom:1rem}
.btc-icon{background:linear-gradient(135deg,oklch(75% 0.18 60),oklch(80% 0.2 55));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.wh-sub{font-size:1.0625rem;color:var(--color-text-secondary);max-width:600px;line-height:1.7;margin-bottom:2rem}
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1rem}
.stat-card{padding:1.25rem 1.5rem;background:oklch(14% 0.03 260/0.8);border:1px solid oklch(28% 0.05 250/0.4);border-radius:.875rem}
.stat-lbl{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:.4rem}
.stat-val{font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--color-text-primary)}.stat-val.accent{color:oklch(80% 0.2 300)}
.stat-chg.pos{color:oklch(72% 0.2 145);font-size:.875rem;font-weight:600}.stat-chg.neg{color:oklch(65% 0.25 25);font-size:.875rem;font-weight:600}
.stat-sm{font-size:.8125rem;color:var(--color-text-muted);margin-top:.25rem}
.wh-main{padding:2rem 0 4rem}
.sec-title{font-family:var(--font-display);font-size:1.375rem;font-weight:700;color:var(--color-text-primary);margin-bottom:.25rem}
.sec-sub{font-size:.875rem;color:var(--color-text-muted);margin-bottom:1.5rem}
.signal-box{margin-top:2.5rem;padding:1.75rem;background:oklch(14% 0.03 260/0.6);border:1px solid oklch(28% 0.05 250/0.4);border-radius:1rem}
.signal-box h3{font-size:1rem;font-weight:700;margin-bottom:1rem}
.sig-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:1rem}
.sig-item{padding:1rem 1.25rem;border-radius:.75rem;font-size:.875rem;line-height:1.6}
.sig-item strong{display:block;margin-bottom:.3rem;font-size:.9375rem}.sig-item p{color:var(--color-text-muted);margin:0}
.bear{background:oklch(65% 0.25 25/0.08);border:1px solid oklch(65% 0.25 25/0.2)}.bear strong{color:oklch(65% 0.25 25)}
.bull{background:oklch(72% 0.2 145/0.08);border:1px solid oklch(72% 0.2 145/0.2)}.bull strong{color:oklch(72% 0.2 145)}
.neut{background:oklch(80% 0.05 195/0.06);border:1px solid oklch(80% 0.05 195/0.2)}
.rel-links{margin-top:2.5rem}.rel-links h3{font-size:1rem;font-weight:700;margin-bottom:1rem}
.rl-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:.75rem}
.rl-card{display:flex;align-items:center;gap:.875rem;padding:1rem 1.25rem;background:oklch(14% 0.03 260/0.6);border:1px solid oklch(28% 0.05 250/0.35);border-radius:.75rem;text-decoration:none;transition:all .2s}
.rl-card:hover{border-color:var(--color-brand-500);transform:translateY(-1px)}
.rl-card span{font-size:1.5rem;width:2.5rem;text-align:center;flex-shrink:0}
.rl-card strong{display:block;font-size:.875rem;font-weight:700;color:var(--color-text-primary)}
.rl-card em{font-style:normal;font-size:.8125rem;color:var(--color-text-muted)}
</style>
