---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CryptoTicker from '../../components/CryptoTicker.astro';
import BlogCard from '../../components/BlogCard.astro';
import MarketData from '../../components/MarketData.astro';
import FAQ from '../../components/FAQ.astro';
import { t } from '../../i18n';
import { getCollection } from 'astro:content';
import { cryptoCategories, siteConfig } from '../../config/site';

import TrendingAlerts from '../../components/hero/TrendingAlerts.astro';
import CoverStory from '../../components/hero/CoverStory.astro';

const locale = 'en';
const tr = t(locale);
const ch = tr.creativeHero;

const allPosts = await getCollection('blog', (p) => !p.data.draft && p.data.locale === 'en');
const sorted = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestPosts = sorted.slice(0, 6);
const featuredPosts = allPosts.filter((p) => p.data.featured).slice(0, 3);

const homepageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: tr.seo.homeTitle,
    description: tr.seo.homeDesc,
    url: `${siteConfig.url}/en/`,
    inLanguage: 'en-US',
    isPartOf: { '@type': 'WebSite', url: siteConfig.url, name: 'KryptoWatch' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: tr.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<BaseLayout
  title={tr.seo.homeTitle}
  description={tr.seo.homeDesc}
  locale="en"
  schema={homepageSchema}
  canonical={`${siteConfig.url}/en/`}
>
  <CryptoTicker />

  <!-- ══ CREATIVE HERO ══ -->
  <section class="creative-hero" aria-labelledby="hero-title">
    <div class="container hero-container">
      <div class="hero-layout">
        <!-- Sidebar Alerts -->
        <aside class="hero-left">
          <TrendingAlerts title={ch.trendingAlerts} alerts={ch.alerts} />
        </aside>

        <!-- Main Feature -->
        <main class="hero-center">
          <CoverStory 
            title={ch.mainTitle}
            subtitle={ch.mainSubtitle}
            badge={ch.coverStory}
            image="/images/hero/ai-agents-evolution.png"
          />
        </main>
      </div>
    </div>
    
    <!-- Background Decor -->
    <div class="hero-scanline"></div>
    <div class="hero-vignette"></div>
  </section>

  <!-- Market Data -->
  <section class="section market-section" aria-labelledby="market-en-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-label" aria-hidden="true">📊 Live Data</p>
        <h2 id="market-en-heading" class="section-title">{tr.sections.marketData}</h2>
        <p class="section-subtitle">{tr.sections.marketDataSubtitle}</p>
      </div>
      <MarketData locale={locale} />
    </div>
  </section>

  <!-- Latest News -->
  {latestPosts.length > 0 && (
    <section class="section" aria-labelledby="latest-en-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label" aria-hidden="true">🔥 Breaking</p>
          <h2 id="latest-en-heading" class="section-title">{tr.sections.latestNews}</h2>
          <p class="section-subtitle">{tr.sections.latestNewsSubtitle}</p>
        </div>
        <div class="blog-grid" role="list">
          {latestPosts.map((post) => (
            <div role="listitem"><BlogCard post={post} locale={locale} /></div>
          ))}
        </div>
        <div class="view-all-wrap">
          <a href="/en/blog/" class="btn btn-outline">{tr.sections.viewAll} →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Featured Analysis -->
  {featuredPosts.length > 0 && (
    <section class="section featured-section" aria-labelledby="featured-en-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label" aria-hidden="true">⭐ Featured</p>
          <h2 id="featured-en-heading" class="section-title">{tr.sections.featuredAnalysis}</h2>
          <p class="section-subtitle">{tr.sections.featuredAnalysisSubtitle}</p>
        </div>
        <div class="blog-grid-featured" role="list">
          {featuredPosts.map((post) => (
            <div role="listitem">
              <BlogCard post={post} locale={locale} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="section" aria-labelledby="cats-en-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-label" aria-hidden="true">🪙 Categories</p>
        <h2 id="cats-en-heading" class="section-title">{tr.sections.marketCategories}</h2>
        <p class="section-subtitle">{tr.sections.marketCategoriesSubtitle}</p>
      </div>
      <div class="categories-grid" role="list">
        {cryptoCategories.map((cat) => (
          <a
            href={cat.slug === 'rsi' ? '/en/rsi/btc/' : `/en/blog/?cat=${cat.slug}`}
            class="category-card"
            role="listitem"
            style={`--cat-color: ${cat.color}`}
          >
            <span class="cat-emoji" aria-hidden="true">{cat.emoji}</span>
            <span class="cat-name">{tr.categories[cat.slug as keyof typeof tr.categories] ?? cat.slug}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section how-section" aria-labelledby="how-en-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-label" aria-hidden="true">🧠 Process</p>
        <h2 id="how-en-heading" class="section-title">{tr.sections.howItWorks}</h2>
        <p class="section-subtitle">{tr.sections.howItWorksSubtitle}</p>
      </div>
      <div class="how-grid" role="list">
        {tr.howItWorks.map((step) => (
          <div class="how-card" role="listitem">
            <div class="how-step-num" aria-hidden="true">{step.step}</div>
            <h3 class="how-title">{step.title}</h3>
            <p class="how-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-en-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-label" aria-hidden="true">❓ FAQ</p>
        <h2 id="faq-en-heading" class="section-title">{tr.sections.faq}</h2>
        <p class="section-subtitle">{tr.sections.faqSubtitle}</p>
      </div>
      <FAQ faqs={tr.faq} locale={locale} />
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Creative Hero ── */
  .creative-hero {
    position: relative;
    padding-block: 4rem;
    background-color: var(--color-surface-950);
    overflow: hidden;
  }

  .hero-container {
    position: relative;
    z-index: 10;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  @media (min-width: 1024px) {
    .hero-layout {
      grid-template-columns: 320px 1fr;
      gap: 1.5rem;
    }
  }

  .hero-left {
    display: none;
  }

  @media (min-width: 768px) {
    .hero-left { display: block; }
  }

  .hero-center {
    min-width: 0;
  }


  /* Scanline effect */
  .hero-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 242, 255, 0.03) 50%,
      transparent 100%
    );
    background-size: 100% 4px;
    animation: scanline 8s linear infinite;
    opacity: 0.5;
  }

  @keyframes scanline {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 6;
    background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.6) 100%);
  }

  .creative-hero::after {
    content: '';
    position: absolute;
    bottom: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 300px;
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Market section */
  .market-section { background: oklch(10% 0.02 260); }

  /* Blog grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }

  .blog-grid-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) { .blog-grid-featured { grid-template-columns: repeat(3, 1fr); } }

  .view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  /* Featured section bg */
  .featured-section {
    background: linear-gradient(180deg, transparent, oklch(10% 0.02 260) 50%, transparent);
  }

  /* Categories */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }

  @media (min-width: 480px) { .categories-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 768px) { .categories-grid { grid-template-columns: repeat(5, 1fr); } }
  @media (min-width: 1024px) { .categories-grid { grid-template-columns: repeat(10, 1fr); } }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 0.75rem;
    background: oklch(14% 0.04 260 / 0.5);
    border: 1px solid oklch(25% 0.05 195 / 0.35);
    border-radius: 0.875rem;
    text-decoration: none;
    transition: all 0.25s;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .category-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--cat-color, var(--color-brand-500));
    opacity: 0;
    transition: opacity 0.25s;
  }

  .category-card:hover {
    border-color: color-mix(in oklch, var(--cat-color) 50%, transparent);
    background: oklch(18% 0.05 260 / 0.7);
    transform: translateY(-3px);
  }

  .category-card:hover::before { opacity: 1; }

  .cat-emoji { font-size: 1.75rem; line-height: 1; }
  .cat-name { font-size: 0.8125rem; font-weight: 600; color: var(--color-text-secondary); }

  /* How it works */
  .how-section { background: oklch(10% 0.02 260); }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) { .how-grid { grid-template-columns: repeat(3, 1fr); } }

  .how-card {
    background: linear-gradient(135deg, oklch(17% 0.04 260 / 0.6), oklch(12% 0.03 260 / 0.4));
    border: 1px solid oklch(25% 0.05 195 / 0.35);
    border-radius: 1rem;
    padding: 2rem;
    position: relative;
    transition: all 0.3s;
  }

  .how-card:hover {
    border-color: var(--color-brand-400);
    transform: translateY(-3px);
    box-shadow: var(--shadow-neon-cyan);
  }

  .how-step-num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 900;
    color: oklch(45% 0.2 195 / 0.1);
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
  }

  .how-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .how-desc { font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.7; }
</style>
