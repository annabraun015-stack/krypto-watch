---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TradingViewChart from '../../../components/rsi/TradingViewChart.astro';
import RSIGauge from '../../../components/rsi/RSIGauge.astro';
import RSIHero from '../../../components/rsi/RSIHero.astro';
import RSITimeframeGrid from '../../../components/rsi/RSITimeframeGrid.astro';
import RSITechnicalSummary from '../../../components/rsi/RSITechnicalSummary.astro';
import RSIScreener from '../../../components/rsi/RSIScreener.astro';
import CoinSidebar from '../../../components/rsi/CoinSidebar.astro';
import { t } from '../../../i18n';
import { siteConfig } from '../../../config/site';

export async function getStaticPaths() {
  const coins = ['btc', 'eth', 'sol', 'bnb', 'xrp', 'ada', 'avax', 'link', 'dot', 'matic'];
  return coins.map((coin) => ({
    params: { coin },
  }));
}

const { coin } = Astro.params;
const locale = 'en';
const tr = t(locale);

const coinName = coin.toUpperCase();
const title = tr.seo.rsiTitle.replace('{coin}', coinName);
const description = tr.seo.rsiDesc.replace('{coin}', coinName);

const rsiUrl = `${siteConfig.url}/en/rsi/${coin}/`;
const altPath = `/rsi/${coin}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: rsiUrl,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'KryptoWatch', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: 'RSI Indicator', item: `${siteConfig.url}/en/rsi/btc/` },
      { '@type': 'ListItem', position: 3, name: coinName }
    ]
  }
};
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  altPath={altPath}
  schema={schema}
  canonical={rsiUrl}
>
  <div class="container">
    <!-- RSI HERO SECTION -->
    <RSIHero symbol={coin} locale={locale} />

    <div class="rsi-dashboard-grid">
      <!-- RSI TIMEFRAME GRID -->
      <section class="dashboard-section">
        <div class="section-header-cyber">
          <div class="header-line"></div>
          <h2 class="section-title-md">MULTITIMEFRAME_RSI_FLOW</h2>
          <p class="section-desc-md">Real-time momentum analysis across all relevant time intervals.</p>
        </div>
        <RSITimeframeGrid symbol={coin} />
      </section>

      <div class="rsi-layout-secondary">
        <main class="rsi-main-content">

          <!-- MAIN CHART -->
          <section class="chart-container-wrap">
            <div class="section-header-cyber">
              <div class="header-line"></div>
              <h2 class="section-title-md">INTERACTIVE_CHART_OSCILLATOR</h2>
            </div>
            <div class="chart-box">
              <TradingViewChart symbol={coin} />
            </div>
          </section>

          <!-- RSI EDUCATION SECTION -->
          <section class="education-grid">
            <div class="edu-card">
              <div class="edu-icon">⚡</div>
              <h3>RSI Strategy</h3>
              <p>Use RSI to identify overbought (>70) or oversold (<30) phases. Divergences between price and RSI often provide strong reversal signals.</p>
            </div>
            <div class="edu-card">
              <div class="edu-icon">🎯</div>
              <h3>Precision Trading</h3>
              <p>Combine RSI values across multiple timeframes to increase the probability of successful trades. Trend alignment is key.</p>
            </div>
          </section>
        </main>

        <aside class="rsi-sidebar-v2">
          <div class="sidebar-widget-wrap">
            <h3 class="widget-title">MARKET_MOMENTUM</h3>
            <RSIGauge symbol={coin} />
          </div>
          
          <RSIScreener locale={locale} />
          
          <CoinSidebar locale={locale} />
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .rsi-dashboard-grid {
    padding-bottom: 5rem;
  }

  .section-header-cyber {
    margin-bottom: 2rem;
    position: relative;
  }

  .header-line {
    width: 60px;
    height: 4px;
    background: var(--color-brand-500);
    margin-bottom: 1rem;
    border-radius: 2px;
  }

  .section-title-md {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .section-desc-md {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 800px;
  }

  .rsi-layout-secondary {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-top: 4rem;
  }

  @media (min-width: 1200px) {
    .rsi-layout-secondary {
      grid-template-columns: 1fr 360px;
    }
  }

  .analysis-card, .chart-container-wrap {
    background: oklch(14% 0.04 250 / 0.4);
    border: 1px solid oklch(25% 0.05 250 / 0.3);
    border-radius: 2rem;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .chart-box {
    margin-top: 1.5rem;
  }

  .education-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .education-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .edu-card {
    background: linear-gradient(145deg, oklch(18% 0.05 250 / 0.6), oklch(12% 0.03 250 / 0.4));
    border: 1px solid oklch(35% 0.1 250 / 0.2);
    border-radius: 1.5rem;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .edu-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .edu-card h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-brand-400);
    margin-bottom: 1rem;
  }

  .edu-card p {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .rsi-sidebar-v2 {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .sidebar-widget-wrap {
    background: oklch(12% 0.03 250 / 0.5);
    border: 1px solid oklch(25% 0.05 250 / 0.3);
    border-radius: 1.5rem;
    padding: 1.5rem;
  }

  .widget-title {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
    text-align: center;
  }
</style>
