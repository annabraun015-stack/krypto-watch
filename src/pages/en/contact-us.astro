---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';
import { siteConfig } from '../../config/site';

const locale = 'en';
const tr = t(locale);
---

<BaseLayout
  title={tr.seo.contactTitle}
  description={tr.seo.contactDesc}
  locale="en"
  canonical={`${siteConfig.url}/en/contact-us/`}
  breadcrumbs={[
    { name: 'KryptoWatch', url: siteConfig.url },
    { name: 'Contact', url: `${siteConfig.url}/en/contact-us/` },
  ]}
>
  <section class="page-hero" aria-labelledby="contact-en-title">
    <div class="container">
      <div class="badge badge-brand" style="margin-bottom: 1rem;">📬 Contact</div>
      <h1 id="contact-en-title" class="page-hero-title">{tr.contact.title}</h1>
      <p class="page-hero-subtitle">{tr.contact.subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="contact-form-wrap">
        <form id="contact-form-en" class="contact-form" novalidate aria-label="Contact Form">
          <div class="form-status" id="form-status-en" role="status" aria-live="polite" hidden></div>

          <div class="form-group">
            <label for="contact-name-en" class="form-label">{tr.contact.name}</label>
            <input type="text" id="contact-name-en" name="name" class="form-input" required autocomplete="name" placeholder="John Doe" aria-required="true" />
          </div>

          <div class="form-group">
            <label for="contact-email-en" class="form-label">{tr.contact.email}</label>
            <input type="email" id="contact-email-en" name="email" class="form-input" required autocomplete="email" placeholder="john@example.com" aria-required="true" />
          </div>

          <div class="form-group">
            <label for="contact-message-en" class="form-label">{tr.contact.message}</label>
            <textarea id="contact-message-en" name="message" class="form-input form-textarea" required rows="6" placeholder="Your message here..." aria-required="true"></textarea>
          </div>

          <button type="submit" id="contact-submit-en" class="btn btn-primary contact-submit">{tr.contact.send}</button>
        </form>
      </div>

      <div class="contact-info">
        <div class="contact-info-card">
          <div class="contact-info-icon">📧</div>
          <h3 class="contact-info-title">Email</h3>
          <p class="contact-info-desc">Direct contact with our editorial team</p>
          <a href={`mailto:${siteConfig.email}`} class="contact-info-link">{siteConfig.email}</a>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon">✈️</div>
          <h3 class="contact-info-title">Telegram</h3>
          <p class="contact-info-desc">Join our crypto community</p>
          <a href={siteConfig.telegram} target="_blank" rel="noopener noreferrer" class="contact-info-link">@kryptowatch</a>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon">🐦</div>
          <h3 class="contact-info-title">Twitter / X</h3>
          <p class="contact-info-desc">Follow us for live crypto news</p>
          <a href={siteConfig.twitterHandle} target="_blank" rel="noopener noreferrer" class="contact-info-link">{siteConfig.twitter}</a>
        </div>
        <div class="contact-info-card contact-disclaimer">
          <p class="contact-disclaimer-text"><strong>Press inquiries:</strong> For press and media inquiries, contact <a href="mailto:press@krypto-watch.de">press@krypto-watch.de</a>.</p>
          <p class="contact-disclaimer-text" style="margin-top: 0.75rem;"><strong>Response times:</strong> We typically respond within 1–2 business days.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding-block: 4rem 3rem; text-align: center; background: radial-gradient(ellipse 70% 50% at 50% -10%, oklch(45% 0.22 250 / 0.12) 0%, transparent 60%); }
  .page-hero-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: var(--color-text-primary); margin-bottom: 1rem; letter-spacing: -0.03em; }
  .page-hero-subtitle { font-size: 1.0625rem; color: var(--color-text-secondary); max-width: 540px; margin-inline: auto; }
  .contact-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 1024px) { .contact-layout { grid-template-columns: 1.2fr 1fr; } }
  .contact-form-wrap { background: oklch(14% 0.04 250 / 0.4); border: 1px solid oklch(25% 0.05 250 / 0.35); border-radius: 1.25rem; padding: 2.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-label { font-size: 0.9rem; font-weight: 600; color: var(--color-text-secondary); }
  .form-textarea { resize: vertical; min-height: 140px; }
  .contact-submit { width: 100%; padding: 0.875rem; font-size: 1rem; }
  .form-status { padding: 1rem; border-radius: 0.625rem; font-size: 0.9375rem; font-weight: 500; margin-bottom: 0.5rem; }
  .form-status.success { background: oklch(72% 0.2 145 / 0.1); border: 1px solid oklch(72% 0.2 145 / 0.3); color: oklch(72% 0.2 145); }
  .form-status.error { background: oklch(65% 0.25 25 / 0.1); border: 1px solid oklch(65% 0.25 25 / 0.3); color: oklch(65% 0.25 25); }
  .contact-info { display: flex; flex-direction: column; gap: 1rem; }
  .contact-info-card { background: oklch(14% 0.04 250 / 0.4); border: 1px solid oklch(25% 0.05 250 / 0.35); border-radius: 1rem; padding: 1.5rem; transition: all 0.25s; }
  .contact-info-card:hover { border-color: oklch(45% 0.2 250 / 0.4); }
  .contact-info-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
  .contact-info-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 0.375rem; }
  .contact-info-desc { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 0.75rem; }
  .contact-info-link { font-size: 0.9375rem; font-weight: 600; color: var(--color-brand-400); text-decoration: none; transition: color 0.2s; }
  .contact-info-link:hover { color: var(--color-brand-300); }
  .contact-disclaimer { background: oklch(17% 0.04 250 / 0.3); }
  .contact-disclaimer-text { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; }
  .contact-disclaimer-text a { color: var(--color-brand-400); text-decoration: none; }
</style>

<script>
  const form = document.getElementById('contact-form-en') as HTMLFormElement;
  const status = document.getElementById('form-status-en') as HTMLDivElement;
  const submitBtn = document.getElementById('contact-submit-en') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
    if (!name || !email || !message) {
      status.className = 'form-status error';
      status.textContent = 'Please fill in all fields.';
      status.hidden = false;
      return;
    }
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;
    await new Promise((res) => setTimeout(res, 1500));
    status.className = 'form-status success';
    status.textContent = '✓ Message sent! We will get back to you within 1–2 business days.';
    status.hidden = false;
    form.reset();
    submitBtn.textContent = 'Send Message';
    submitBtn.disabled = false;
  });
</script>
