---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnlockCard from '../../components/unlocks/UnlockCard.astro';
import FAQ from '../../components/FAQ.astro';
import { siteConfig } from '../../config/site';
import { t } from '../../i18n';

import fs from 'fs';
import path from 'path';

const locale = 'de';
const tr = t(locale);

// Phase 1B: Dynamic Data Ingestion
const dataPath = path.resolve(process.cwd(), 'src/data/unlocks-master.json');
const masterData = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));

const allUnlocks: any[] = [];
masterData.forEach((coin: any) => {
  coin.unlocks.forEach((u: any) => {
    allUnlocks.push({
      ...u,
      coinId: coin.slug,
      symbol: coin.symbol,
      name: coin.name,
      unlockDate: new Date(u.date),
      marketCap: coin.marketCap,
      volume24h: coin.volume24h
    });
  });
});

const sortedUnlocks = allUnlocks.sort((a, b) => a.unlockDate.getTime() - b.unlockDate.getTime());

// SEO: ItemList Schema
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Upcoming Crypto Token Unlocks",
  "description": "Real-time monitor of major cryptocurrency token unlock events and supply shock analysis.",
  "itemListElement": sortedUnlocks.map((unlock, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Event",
      "name": `${unlock.name} Token Unlock`,
      "startDate": unlock.unlockDate.toISOString()
    }
  }))
};

// SEO: FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": tr.unlocks.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const pageTitle = tr.unlocks.seoTitle;
const pageDesc = tr.unlocks.seoDesc;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  locale={locale}
  canonical={`${siteConfig.url}/token-unlocks/`}
>
  <!-- SEO: Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <div class="unlocks-page">
    <!-- ══ DASHBOARD HEADER ══ -->
    <header class="dashboard-header">
      <div class="container">
        <div class="header-content">
          <div class="badge-row">
            <span class="pulse-badge"><span class="dot"></span> {tr.unlocks.liveMonitor}</span>
            <span class="tech-tag">{tr.unlocks.phaseAlpha}</span>
          </div>
          <h1 class="glitch-title" data-text={tr.unlocks.dashboardTitle}>{tr.unlocks.dashboardTitle}</h1>
          <p class="header-subtitle">
            {tr.unlocks.dashboardSubtitle}
          </p>
          
          <div class="stats-overview">
            <div class="overview-card">
              <span class="label">{tr.unlocks.majorUnlocks}</span>
              <span class="value">12</span>
            </div>
            <div class="overview-card">
              <span class="label">{tr.unlocks.totalValue}</span>
              <span class="value">$1.48B</span>
            </div>
            <div class="overview-card">
              <span class="label">{tr.unlocks.highestImpact}</span>
              <span class="value" style="color: #ff003c">WLD (5.2%)</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Background elements -->
      <div class="header-grid"></div>
      <div class="header-glow"></div>
    </header>

    <!-- ══ FILTER BAR ══ -->
    <nav class="filter-bar">
      <div class="container">
        <div class="filter-flex">
          <div class="filter-group">
            <button class="filter-btn active">{tr.unlocks.allUnlocks}</button>
            <button class="filter-btn">{tr.unlocks.today}</button>
            <button class="filter-btn">{tr.unlocks.thisWeek}</button>
            <button class="filter-btn">{tr.unlocks.thisMonth}</button>
          </div>
          <div class="search-box">
            <input type="text" placeholder={tr.unlocks.searchPlaceholder} />
          </div>
        </div>
      </div>
    </nav>

    <!-- ══ MONTHLY ARCHIVES (Phase 1B Internal Linking) ══ -->
    <section class="archive-nav">
      <div class="container">
        <div class="archive-flex">
          <span class="archive-label">Browse by Month:</span>
          <div class="month-links">
            <a href="/token-unlocks/april-2026" class="month-link">April 2026</a>
            <a href="/token-unlocks/may-2026" class="month-link">May 2026</a>
            <a href="/token-unlocks/june-2026" class="month-link">June 2026</a>
            <a href="/token-unlocks/july-2026" class="month-link">July 2026</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ MAIN CONTENT ══ -->
    <main class="main-content">
      <div class="container">
        <div class="unlock-grid">
          {sortedUnlocks.map(unlock => (
            <UnlockCard unlock={unlock} locale={locale} />
          ))}
        </div>
        
        <div class="load-more">
          <p class="disclaimer">
            {tr.unlocks.disclaimer}
          </p>
          <button class="btn btn-outline">{tr.unlocks.loadMore}</button>
        </div>

        <!-- ══ FAQ SECTION ══ -->
        <section class="faq-section">
          <div class="section-header">
            <h2 class="section-title">{tr.unlocks.faqTitle}</h2>
            <div class="title-underline"></div>
          </div>
          <FAQ faqs={tr.unlocks.faqs} locale={locale} />
        </section>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .unlocks-page {
    background-color: var(--color-surface-950);
    min-height: 100vh;
  }

  /* ── Header ── */
  .dashboard-header {
    position: relative;
    padding-block: 6rem 4rem;
    background: radial-gradient(circle at 70% 20%, oklch(25% 0.1 260 / 0.15), transparent 50%);
    overflow: hidden;
    border-bottom: 1px solid oklch(25% 0.05 195 / 0.3);
  }

  .header-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
  }

  .badge-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .pulse-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.625rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: oklch(20% 0.04 260);
    border: 1px solid oklch(45% 0.2 195 / 0.3);
    border-radius: 2rem;
    color: #00f3ff;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: #00f3ff;
    border-radius: 50%;
    box-shadow: 0 0 8px #00f3ff;
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .tech-tag {
    font-size: 0.625rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: oklch(20% 0.04 260);
    border: 1px solid oklch(25% 0.05 195 / 0.3);
    border-radius: 2rem;
    color: var(--color-text-secondary);
  }

  .glitch-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: white;
    letter-spacing: -0.02em;
  }

  .header-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .stats-overview {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .overview-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .overview-card .label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .overview-card .value {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
  }

  /* ── Background Decorations ── */
  .header-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(to right, oklch(25% 0.05 195 / 0.1) 1px, transparent 1px),
      linear-gradient(to bottom, oklch(25% 0.05 195 / 0.1) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: linear-gradient(to bottom, black, transparent);
    z-index: 1;
  }

  .header-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle at center, oklch(60% 0.2 195 / 0.05), transparent 70%);
    z-index: 2;
  }

  /* ── Filter Bar ── */
  .filter-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(10% 0.02 260 / 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid oklch(25% 0.05 195 / 0.3);
    padding-block: 1rem;
  }

  .filter-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    gap: 0.5rem;
    background: oklch(15% 0.04 260);
    padding: 0.25rem;
    border-radius: 0.75rem;
    border: 1px solid oklch(25% 0.05 195 / 0.2);
  }

  .filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: all 0.2s;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .filter-btn.active {
    background: oklch(25% 0.05 195 / 0.4);
    color: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .search-box input {
    background: oklch(15% 0.04 260);
    border: 1px solid oklch(25% 0.05 195 / 0.3);
    border-radius: 0.75rem;
    padding: 0.625rem 1.25rem;
    color: white;
    font-size: 0.875rem;
    min-width: 260px;
  }

  /* ── Archive Nav ── */
  .archive-nav {
    background: oklch(12% 0.03 260);
    padding-block: 1rem;
    border-bottom: 1px solid oklch(25% 0.05 195 / 0.1);
  }

  .archive-flex {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .archive-label {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .month-links {
    display: flex;
    gap: 0.75rem;
  }

  .month-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    background: oklch(20% 0.04 260);
    border-radius: 0.5rem;
    border: 1px solid oklch(25% 0.05 195 / 0.2);
    transition: all 0.2s;
  }

  .month-link:hover {
    color: var(--color-brand-400);
    border-color: var(--color-brand-400);
    background: oklch(25% 0.05 195 / 0.1);
  }

  /* ── Main Content ── */
  .main-content {
    padding-block: 4rem 6rem;
  }

  .unlock-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .unlock-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1200px) {
    .unlock-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .load-more {
    margin-top: 4rem;
    text-align: center;
  }

  .disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  /* ── FAQ Section ── */
  .faq-section {
    margin-top: 6rem;
    padding-top: 4rem;
    border-top: 1px solid oklch(25% 0.05 195 / 0.2);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: white;
    margin-bottom: 1rem;
  }

  .title-underline {
    width: 60px;
    height: 4px;
    background: var(--color-brand-400);
    margin: 0 auto;
    border-radius: 2px;
    box-shadow: 0 0 10px var(--color-brand-400);
  }
</style>
