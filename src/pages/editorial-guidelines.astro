---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const title = "Redaktionelle Richtlinien | KryptoWatch";
const description = "Erfahren Sie mehr über unsere redaktionellen Standards, unseren Faktencheck-Prozess und unser Engagement für Integrität und Transparenz im Krypto-Journalismus.";

const guidelines = [
  {
    title: "Redaktionelle Unabhängigkeit",
    content: "Unsere Redaktion arbeitet vollkommen unabhängig von externen Einflüssen. Wir akzeptieren keine Zahlungen für positive Berichterstattung oder 'Shilling' von Token. Alle redaktionellen Entscheidungen werden ausschließlich auf Basis von Relevanz, Genauigkeit und Mehrwert für unsere Leser getroffen."
  },
  {
    title: "Strikter Faktencheck-Prozess",
    content: "Jeder technische Artikel auf KryptoWatch durchläuft einen zweistufigen Verifizierungsprozess. Zunächst wird der Inhalt von einem spezialisierten Autor verfasst und anschließend von einem zweiten Experten (z.B. Dr. Marcus Richter für Bitcoin oder Sophia Wagner für Ethereum) auf technische Richtigkeit und Aktualität geprüft."
  },
  {
    title: "Transparenz & Offenlegung",
    content: "Wir glauben an absolute Transparenz. Unsere Autoren sind verpflichtet, etwaige persönliche Positionen in den besprochenen Kryptowährungen offenzulegen, sofern diese einen signifikanten Einfluss auf die Berichterstattung haben könnten. Wir kennzeichnen gesponserte Inhalte (sofern vorhanden) deutlich als solche."
  },
  {
    title: "Korrekturrichtlinie",
    content: "Trotz höchster Sorgfalt können Fehler passieren. Wenn wir auf Ungenauigkeiten aufmerksam gemacht werden, korrigieren wir diese umgehend und transparent. Jede signifikante Änderung an einem bereits veröffentlichten Artikel wird mit einem 'Zuletzt aktualisiert'-Zeitstempel versehen."
  },
  {
    title: "KI-Nutzung",
    content: "Wir nutzen moderne Technologien zur Datenanalyse und Strukturierung, aber jeder Artikel wird von menschlichen Experten finalisiert, kuratiert und verifiziert. Wir glauben, dass echte Expertise (Experience & Expertise) nicht durch Algorithmen ersetzt werden kann."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  locale="de"
  canonical={`${siteConfig.url}/editorial-guidelines/`}
  breadcrumbs={[
    { name: 'KryptoWatch', url: '/' },
    { name: 'Redaktionelle Richtlinien', url: '/editorial-guidelines/' },
  ]}
>
  <div class="guidelines-page py-16 md:py-24">
    <div class="container max-w-4xl">
      <header class="mb-12 text-center">
        <div class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-widest uppercase rounded-full bg-brand-500/10 text-brand-400 border border-brand-500/20">
          E-E-A-T Standard
        </div>
        <h1 class="text-4xl md:text-5xl font-black mb-6 font-display tracking-tight text-white">
          Redaktionelle <span class="text-gradient">Richtlinien</span>
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed max-w-2xl mx-auto">
          Integrität ist das Fundament unseres Handelns. Wir setzen höchste Maßstäbe an die Qualität und Verlässlichkeit unserer Informationen.
        </p>
      </header>

      <div class="space-y-8">
        {guidelines.map((item, index) => (
          <section class="guideline-card p-8 rounded-2xl bg-slate-900/50 border border-slate-800 hover:border-brand-500/30 transition-colors shadow-xl">
            <div class="flex items-start gap-5">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-500/20 flex items-center justify-center text-brand-400 font-bold font-display border border-brand-500/30">
                {index + 1}
              </div>
              <div>
                <h2 class="text-xl font-bold mb-3 text-white font-display">{item.title}</h2>
                <p class="text-slate-400 leading-relaxed">
                  {item.content}
                </p>
              </div>
            </div>
          </section>
        ))}
      </div>

      <footer class="mt-16 p-8 rounded-2xl bg-brand-900/20 border border-brand-500/20 text-center">
        <h3 class="text-lg font-bold mb-3 text-white">Haben Sie Fragen oder Korrekturen?</h3>
        <p class="text-slate-400 mb-6">
          Ihre Rückmeldung hilft uns, unsere Standards kontinuierlich zu verbessern.
        </p>
        <a href="/contact-us/" class="btn btn-primary inline-flex items-center gap-2">
          Redaktion kontaktieren
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15.8333 10H4.16667M15.8333 10L10.8333 5M15.8333 10L10.8333 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .text-gradient {
    background: linear-gradient(135deg, var(--color-brand-400), var(--color-brand-600));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .guideline-card {
    position: relative;
    overflow: hidden;
  }
  .guideline-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background: linear-gradient(to bottom, var(--color-brand-500), transparent);
    opacity: 0.5;
  }
</style>
