---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignalBadge from '../components/onchain/SignalBadge.astro';
import { fetchPrices, fetchExchangeFlows, formatUsd } from '../lib/onchain';

const prices = await fetchPrices();
const flows  = await fetchExchangeFlows(prices);
const btcFlow = flows.find(f => f.token === 'BTC')!;
const ethFlow = flows.find(f => f.token === 'ETH')!;
---

<BaseLayout
  title="Exchange Flows — BTC & ETH Inflow/Outflow Dashboard | KryptoWatch"
  description="Verfolge Bitcoin und Ethereum Inflows und Outflows auf Exchanges. Bullish/Bearish Signale basierend auf Akkumulation und Verkaufsdruck."
  canonical="https://kryptowatch.de/exchange-flows/"
  locale="de"
  altPath="/en/exchange-flows/"
  breadcrumbs={[{ name: 'Home', url: 'https://kryptowatch.de/' }, { name: 'Exchange Flows', url: 'https://kryptowatch.de/exchange-flows/' }]}
>
  <section class="ef-hero">
    <div class="container">
      <div class="ef-badge"><span class="ldot"></span> 24h Rolling Data</div>
      <h1 class="ef-title">Exchange Flow Dashboard</h1>
      <p class="ef-sub">Echtzeit-Übersicht der Coin-Bewegungen in und aus Kryptobörsen. Hoher Inflow = potentieller Verkaufsdruck. Hoher Outflow = Akkumulations-Signal.</p>
    </div>
  </section>

  <section class="ef-main">
    <div class="container">
      <!-- BTC Flow Card -->
      <div class="flow-card" id="btc-flow">
        <div class="flow-header">
          <div class="flow-coin">
            <span class="coin-icon btc-color">₿</span>
            <div>
              <div class="coin-name">Bitcoin</div>
              <div class="coin-price">{formatUsd(prices.btc)} <span class={prices.btcChange24h >= 0 ? 'pos' : 'neg'}>{prices.btcChange24h >= 0 ? '▲' : '▼'}{Math.abs(prices.btcChange24h).toFixed(2)}%</span></div>
            </div>
          </div>
          <SignalBadge signal={btcFlow.signal} size="md" reason={btcFlow.signalReason} />
        </div>

        <div class="flow-metrics">
          <div class="metric inflow-m">
            <div class="metric-lbl">⬇ Exchange Inflow (24h)</div>
            <div class="metric-val">{formatUsd(btcFlow.inflow24h)}</div>
            <div class={`metric-chg ${btcFlow.inflowChange7d >= 0 ? 'neg' : 'pos'}`}>
              {btcFlow.inflowChange7d >= 0 ? '▲' : '▼'} {Math.abs(btcFlow.inflowChange7d).toFixed(1)}% gg. Vorwoche
            </div>
          </div>
          <div class="metric outflow-m">
            <div class="metric-lbl">⬆ Exchange Outflow (24h)</div>
            <div class="metric-val">{formatUsd(btcFlow.outflow24h)}</div>
            <div class={`metric-chg ${btcFlow.outflowChange7d >= 0 ? 'pos' : 'neg'}`}>
              {btcFlow.outflowChange7d >= 0 ? '▲' : '▼'} {Math.abs(btcFlow.outflowChange7d).toFixed(1)}% gg. Vorwoche
            </div>
          </div>
          <div class="metric netflow-m">
            <div class="metric-lbl">⇄ Netto-Flow (24h)</div>
            <div class={`metric-val ${btcFlow.netFlow24h > 0 ? 'neg-val' : 'pos-val'}`}>
              {btcFlow.netFlow24h > 0 ? '+' : ''}{formatUsd(btcFlow.netFlow24h)}
            </div>
            <div class="metric-note">{btcFlow.netFlow24h > 0 ? 'Netto Inflow — bearish' : 'Netto Outflow — bullish'}</div>
          </div>
        </div>

        <div class="signal-reason">
          <span class="sr-icon">💡</span>
          {btcFlow.signalReason}
        </div>

        <!-- Flow Bar Chart (rendered client-side) -->
        <div class="chart-section">
          <div class="chart-lbl">7-Tage Flow-Verlauf</div>
          <canvas id="btc-flow-chart" class="flow-canvas" height="120" aria-hidden="true"></canvas>
        </div>
      </div>

      <!-- ETH Flow Card -->
      <div class="flow-card" id="eth-flow">
        <div class="flow-header">
          <div class="flow-coin">
            <span class="coin-icon eth-color">Ξ</span>
            <div>
              <div class="coin-name">Ethereum</div>
              <div class="coin-price">{formatUsd(prices.eth)} <span class={prices.ethChange24h >= 0 ? 'pos' : 'neg'}>{prices.ethChange24h >= 0 ? '▲' : '▼'}{Math.abs(prices.ethChange24h).toFixed(2)}%</span></div>
            </div>
          </div>
          <SignalBadge signal={ethFlow.signal} size="md" reason={ethFlow.signalReason} />
        </div>

        <div class="flow-metrics">
          <div class="metric inflow-m">
            <div class="metric-lbl">⬇ Exchange Inflow (24h)</div>
            <div class="metric-val">{formatUsd(ethFlow.inflow24h)}</div>
            <div class={`metric-chg ${ethFlow.inflowChange7d >= 0 ? 'neg' : 'pos'}`}>
              {ethFlow.inflowChange7d >= 0 ? '▲' : '▼'} {Math.abs(ethFlow.inflowChange7d).toFixed(1)}% gg. Vorwoche
            </div>
          </div>
          <div class="metric outflow-m">
            <div class="metric-lbl">⬆ Exchange Outflow (24h)</div>
            <div class="metric-val">{formatUsd(ethFlow.outflow24h)}</div>
            <div class={`metric-chg ${ethFlow.outflowChange7d >= 0 ? 'pos' : 'neg'}`}>
              {ethFlow.outflowChange7d >= 0 ? '▲' : '▼'} {Math.abs(ethFlow.outflowChange7d).toFixed(1)}% gg. Vorwoche
            </div>
          </div>
          <div class="metric netflow-m">
            <div class="metric-lbl">⇄ Netto-Flow (24h)</div>
            <div class={`metric-val ${ethFlow.netFlow24h > 0 ? 'neg-val' : 'pos-val'}`}>
              {ethFlow.netFlow24h > 0 ? '+' : ''}{formatUsd(ethFlow.netFlow24h)}
            </div>
            <div class="metric-note">{ethFlow.netFlow24h > 0 ? 'Netto Inflow — bearish' : 'Netto Outflow — bullish'}</div>
          </div>
        </div>

        <div class="signal-reason">
          <span class="sr-icon">💡</span>
          {ethFlow.signalReason}
        </div>

        <div class="chart-section">
          <div class="chart-lbl">7-Tage Flow-Verlauf</div>
          <canvas id="eth-flow-chart" class="flow-canvas" height="120" aria-hidden="true"></canvas>
        </div>
      </div>

      <!-- Guide -->
      <div class="ef-guide">
        <h3>📖 Wie liest man Exchange Flows?</h3>
        <div class="guide-grid">
          <div class="guide-item"><strong>Hoher Inflow → Bearish</strong><p>Wenn viele Coins auf Exchanges fließen, signalisiert das oft Verkaufsabsichten. Anleger senden ihre Coins zu Börsen, um sie dort zu verkaufen.</p></div>
          <div class="guide-item"><strong>Hoher Outflow → Bullish</strong><p>Coins die Exchanges verlassen und in private Wallets fließen, deuten auf Langzeit-Akkumulation hin. HODLer ziehen ihre Coins ab.</p></div>
          <div class="guide-item"><strong>Kombination mit Preis</strong><p>Outflow + steigender Preis = starkes Bullish-Signal. Inflow + fallender Preis = mögliche Kapitulation.</p></div>
        </div>
      </div>

      <div class="rel-links">
        <h3>Weitere Analytics</h3>
        <div class="rl-grid">
          <a href="/bitcoin-whale-tracker/" class="rl-card"><span>₿</span><div><strong>BTC Whale Tracker</strong><em>Einzelne Großtransaktionen</em></div></a>
          <a href="/ethereum-whale-tracker/" class="rl-card"><span>Ξ</span><div><strong>ETH Whale Tracker</strong><em>Einzelne Großtransaktionen</em></div></a>
          <a href="/smart-money/" class="rl-card"><span>🧠</span><div><strong>Smart Money</strong><em>Top-Wallets nach ROI</em></div></a>
          <a href="/exchange-reserves/" class="rl-card"><span>🏦</span><div><strong>Exchange Reserves</strong><em>Historische Bestände</em></div></a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
function drawFlowChart(canvasId: string, history: {date:string,inflow:number,outflow:number}[]) {
  const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
  if (!canvas) return;
  canvas.width = canvas.offsetWidth;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width, H = canvas.height;
  const pad = { top: 10, right: 10, bottom: 30, left: 10 };
  const cW = W - pad.left - pad.right;
  const cH = H - pad.top - pad.bottom;
  const allVals = history.flatMap(d => [d.inflow, d.outflow]);
  const maxV = Math.max(...allVals);
  const n = history.length;
  const bw = (cW / n) * 0.35;
  const gap = cW / n;

  ctx.clearRect(0, 0, W, H);

  // Grid lines
  ctx.strokeStyle = 'oklch(30% 0.05 250 / 0.3)';
  ctx.lineWidth = 0.5;
  [0.25, 0.5, 0.75, 1].forEach(r => {
    const y = pad.top + cH * (1 - r);
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
  });

  history.forEach((d, i) => {
    const x = pad.left + i * gap + gap / 2;
    const ih = (d.inflow / maxV) * cH;
    const oh = (d.outflow / maxV) * cH;

    // Inflow bar (red)
    ctx.fillStyle = 'oklch(65% 0.25 25 / 0.7)';
    ctx.fillRect(x - bw - 2, pad.top + cH - ih, bw, ih);

    // Outflow bar (green)
    ctx.fillStyle = 'oklch(72% 0.2 145 / 0.7)';
    ctx.fillRect(x + 2, pad.top + cH - oh, bw, oh);

    // Date label
    ctx.fillStyle = 'oklch(60% 0.04 195)';
    ctx.font = '9px Inter, sans-serif';
    ctx.textAlign = 'center';
    const day = d.date.slice(5);
    ctx.fillText(day, x, H - 5);
  });

  // Legend
  ctx.font = '9px Inter, sans-serif';
  ctx.fillStyle = 'oklch(65% 0.25 25)';
  ctx.textAlign = 'left';
  ctx.fillText('█ Inflow', pad.left, pad.top + 8);
  ctx.fillStyle = 'oklch(72% 0.2 145)';
  ctx.fillText('█ Outflow', pad.left + 55, pad.top + 8);
}

document.addEventListener('DOMContentLoaded', () => {
  const btcData = (window as any).__btcFlowHistory;
  const ethData = (window as any).__ethFlowHistory;
  if (btcData) drawFlowChart('btc-flow-chart', btcData);
  if (ethData) drawFlowChart('eth-flow-chart', ethData);
  window.addEventListener('resize', () => {
    if (btcData) drawFlowChart('btc-flow-chart', btcData);
    if (ethData) drawFlowChart('eth-flow-chart', ethData);
  });
});
</script>

<script define:vars={{ btcHistory: btcFlow.history, ethHistory: ethFlow.history }}>
window.__btcFlowHistory = btcHistory;
window.__ethFlowHistory = ethHistory;
document.dispatchEvent(new Event('DOMContentLoaded'));
</script>

<style>
.ef-hero { padding:3.5rem 0 2rem; background:radial-gradient(ellipse 70% 50% at 50% -10%, oklch(53% 0.26 195/0.08) 0%, transparent 60%); }
.ef-badge { display:inline-flex; align-items:center; gap:.5rem; padding:.375rem .875rem; background:oklch(53% 0.26 195/0.12); border:1px solid oklch(53% 0.26 195/0.3); border-radius:100px; font-size:.75rem; font-weight:700; color:var(--color-brand-300); text-transform:uppercase; letter-spacing:.08em; margin-bottom:1.25rem; }
.ldot { width:7px; height:7px; border-radius:50%; background:oklch(72% 0.2 145); box-shadow:0 0 6px oklch(72% 0.2 145); animation:pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
.ef-title { font-family:var(--font-display); font-size:clamp(1.875rem,5vw,3rem); font-weight:900; line-height:1.1; margin-bottom:1rem; }
.ef-sub { font-size:1.0625rem; color:var(--color-text-secondary); max-width:640px; line-height:1.7; }
.ef-main { padding:2rem 0 4rem; }
.ef-main .container { display:flex; flex-direction:column; gap:1.75rem; }

.flow-card { padding:1.75rem; background:oklch(13% 0.03 260/0.8); border:1px solid oklch(28% 0.05 250/0.4); border-radius:1.25rem; }
.flow-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:1.5rem; }
.flow-coin { display:flex; align-items:center; gap:1rem; }
.coin-icon { font-size:2rem; font-weight:900; }
.btc-color { color:oklch(75% 0.18 60); }
.eth-color { color:oklch(68% 0.14 280); }
.coin-name { font-family:var(--font-display); font-size:1.125rem; font-weight:700; color:var(--color-text-primary); }
.coin-price { font-size:.875rem; color:var(--color-text-muted); }
.coin-price .pos { color:oklch(72% 0.2 145); } .coin-price .neg { color:oklch(65% 0.25 25); }

.flow-metrics { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:1rem; margin-bottom:1.25rem; }
.metric { padding:1rem 1.25rem; border-radius:.875rem; }
.inflow-m { background:oklch(65% 0.25 25/0.07); border:1px solid oklch(65% 0.25 25/0.2); }
.outflow-m { background:oklch(72% 0.2 145/0.07); border:1px solid oklch(72% 0.2 145/0.2); }
.netflow-m { background:oklch(53% 0.26 195/0.07); border:1px solid oklch(53% 0.26 195/0.2); }
.metric-lbl { font-size:.75rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:.5rem; }
.metric-val { font-family:var(--font-display); font-size:1.375rem; font-weight:800; color:var(--color-text-primary); }
.metric-val.neg-val { color:oklch(65% 0.25 25); } .metric-val.pos-val { color:oklch(72% 0.2 145); }
.metric-chg { font-size:.8125rem; font-weight:600; margin-top:.25rem; }
.metric-chg.pos { color:oklch(72% 0.2 145); } .metric-chg.neg { color:oklch(65% 0.25 25); }
.metric-note { font-size:.75rem; color:var(--color-text-muted); margin-top:.25rem; }

.signal-reason { display:flex; align-items:flex-start; gap:.625rem; padding:.875rem 1rem; background:oklch(17% 0.04 260/0.5); border-radius:.75rem; font-size:.875rem; color:var(--color-text-secondary); line-height:1.5; margin-bottom:1.25rem; }
.sr-icon { font-size:1rem; flex-shrink:0; margin-top:.1rem; }

.chart-section { }
.chart-lbl { font-size:.75rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:.5rem; }
.flow-canvas { width:100%; display:block; border-radius:.5rem; background:oklch(10% 0.02 260/0.5); }

.ef-guide { padding:1.75rem; background:oklch(14% 0.03 260/0.6); border:1px solid oklch(28% 0.05 250/0.4); border-radius:1rem; }
.ef-guide h3 { font-size:1rem; font-weight:700; margin-bottom:1rem; }
.guide-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:1rem; }
.guide-item { padding:1rem 1.25rem; background:oklch(17% 0.04 260/0.5); border:1px solid oklch(28% 0.05 250/0.3); border-radius:.75rem; font-size:.875rem; line-height:1.6; }
.guide-item strong { display:block; margin-bottom:.3rem; font-size:.9rem; color:var(--color-brand-300); }
.guide-item p { color:var(--color-text-muted); margin:0; }

.rel-links h3 { font-size:1rem; font-weight:700; margin-bottom:1rem; }
.rl-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:.75rem; }
.rl-card { display:flex; align-items:center; gap:.875rem; padding:1rem 1.25rem; background:oklch(14% 0.03 260/0.6); border:1px solid oklch(28% 0.05 250/0.35); border-radius:.75rem; text-decoration:none; transition:all .2s; }
.rl-card:hover { border-color:var(--color-brand-500); transform:translateY(-1px); }
.rl-card span { font-size:1.5rem; width:2.5rem; text-align:center; flex-shrink:0; }
.rl-card strong { display:block; font-size:.875rem; font-weight:700; color:var(--color-text-primary); }
.rl-card em { font-style:normal; font-size:.8125rem; color:var(--color-text-muted); }
</style>
