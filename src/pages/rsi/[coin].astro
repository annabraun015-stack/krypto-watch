---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TradingViewChart from '../../components/rsi/TradingViewChart.astro';
import RSIGauge from '../../components/rsi/RSIGauge.astro';
import RSIHero from '../../components/rsi/RSIHero.astro';
import RSITimeframeGrid from '../../components/rsi/RSITimeframeGrid.astro';
import CoinSidebar from '../../components/rsi/CoinSidebar.astro';
import { t } from '../../i18n';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const coins = ['btc', 'eth', 'sol', 'bnb', 'xrp', 'ada', 'avax', 'link', 'dot', 'matic'];
  return coins.map((coin) => ({
    params: { coin },
  }));
}

const { coin } = Astro.params;
const locale = 'de';
const tr = t(locale);

const coinName = coin.toUpperCase();
const title = tr.seo.rsiTitle.replace('{coin}', coinName);
const description = tr.seo.rsiDesc.replace('{coin}', coinName);

const rsiUrl = `${siteConfig.url}/rsi/${coin}/`;
const altPath = `/en/rsi/${coin}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: rsiUrl,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'KryptoWatch', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: 'RSI Indikator', item: `${siteConfig.url}/rsi/btc/` },
      { '@type': 'ListItem', position: 3, name: coinName }
    ]
  }
};
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  altPath={altPath}
  schema={schema}
  canonical={rsiUrl}
>
    <div class="container">
      <!-- RSI HERO SECTION -->
      <RSIHero symbol={coin} locale={locale} />

      <!-- RSI TIMEFRAME GRID -->
      <section class="section-wrap">
        <div class="section-header-simple">
          <h2 class="section-title-sm">Multitimeframe RSI Status</h2>
          <p class="section-desc-sm">Live RSI Analyse über verschiedene Zeitintervalle.</p>
        </div>
        <RSITimeframeGrid symbol={coin} />
      </section>

      <div class="rsi-layout">
        <main class="rsi-main">
          <!-- MAIN CHART -->
          <section class="chart-section-wrap">
            <div class="section-header-simple">
              <h2 class="section-title-sm">Interaktiver RSI Chart</h2>
            </div>
            <TradingViewChart symbol={coin} />
          </section>

          <!-- TECHNICAL SUMMARY -->
          <section class="chart-section-wrap">
            <div class="section-header-simple">
              <h2 class="section-title-sm">Technische Analyse Zusammenfassung</h2>
            </div>
            <div class="tradingview-widget-container">
              <div id="tv-technical-summary" class="tv-widget-container"></div>
              <script is:inline define:vars={{ tvSymbol }}>
                function loadSummary() {
                  const container = document.getElementById('tv-technical-summary');
                  if (!container) return;
                  const script = document.createElement('script');
                  script.type = 'text/javascript';
                  script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-technical-analysis.js';
                  script.async = true;
                  script.innerHTML = JSON.stringify({
                    "interval": "1h",
                    "width": "100%",
                    "isTransparent": true,
                    "height": "400",
                    "symbol": tvSymbol,
                    "showIntervalTabs": true,
                    "displayMode": "multiple",
                    "locale": "de",
                    "colorTheme": "dark"
                  });
                  container.appendChild(script);
                }
                if (document.readyState === 'complete') loadSummary();
                else window.addEventListener('load', loadSummary);
              </script>
            </div>
          </section>

          <!-- RSI EDUCATION SECTION -->
          <section class="info-section">
            <div class="info-grid">
              <div class="info-card">
                <div class="info-icon">🧠</div>
                <h3>Was ist der RSI?</h3>
                <p>Der Relative Strength Index (RSI) ist ein Momentum-Indikator, der das Ausmaß der jüngsten Kursveränderungen misst, um überkaufte oder überverkaufte Bedingungen im Kurs eines Assets zu bewerten.</p>
              </div>
              <div class="info-card">
                <div class="info-icon">📊</div>
                <h3>Interpretation</h3>
                <p>Ein RSI-Wert über 70 gilt traditionell als überkauft (Verkaufssignal), während ein Wert unter 30 als überverkauft gilt (Kaufsignal).</p>
              </div>
            </div>
          </section>
        </main>

        <aside class="rsi-sidebar">
          <RSIGauge symbol={coin} />
          <CoinSidebar locale={locale} />
        </aside>
      </div>
    </div>
</BaseLayout>

<style>
  .rsi-page {
    padding-bottom: 5rem;
  }

  .rsi-header {
    padding-block: 4rem 3rem;
    background: radial-gradient(circle at 20% 50%, oklch(45% 0.22 195 / 0.05) 0%, transparent 50%);
    border-bottom: 1px solid oklch(25% 0.05 250 / 0.2);
    margin-bottom: 3rem;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .header-content {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .page-title .highlight {
    color: var(--color-brand-400);
    display: block;
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
  }

  .rsi-badges {
    display: flex;
    gap: 0.75rem;
  }

  .rsi-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 2rem;
  }

  @media (min-width: 1024px) {
    .rsi-layout {
      grid-template-columns: 1fr 340px;
    }
  }

  .section-wrap {
    margin-bottom: 3rem;
  }

  .section-header-simple {
    margin-bottom: 1.5rem;
  }

  .section-title-sm {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .section-desc-sm {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .chart-section-wrap {
    background: oklch(14% 0.04 250 / 0.3);
    border: 1px solid oklch(25% 0.05 250 / 0.2);
    border-radius: 1.5rem;
    padding: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .rsi-main {
    display: flex;
    flex-direction: column;
  }

  .rsi-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .info-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .info-card {
    background: oklch(14% 0.04 250 / 0.3);
    border: 1px solid oklch(25% 0.05 250 / 0.2);
    border-radius: 1rem;
    padding: 2rem;
    position: relative;
  }

  .info-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-brand-300);
    margin-bottom: 1rem;
  }

  .info-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>
