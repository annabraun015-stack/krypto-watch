---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ListingCard from '../../../components/listings/ListingCard.astro';
import { siteConfig } from '../../../config/site';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const dataPath = path.resolve(process.cwd(), 'src/data/listings-master.json');
  const masterData = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  
  return masterData.map((ex: any) => ({
    params: { exchange: ex.exchange },
    props: { listings: ex.listings }
  }));
}

const { exchange } = Astro.params;
const { listings } = Astro.props;

const pageTitle = `${exchange.toUpperCase()} New Listings Intelligence | KryptoWatch`;
const pageDesc = `Real-time impact analysis and volume tracking for new cryptocurrency listings on ${exchange.toUpperCase()}.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  locale="de"
  canonical={`${siteConfig.url}/exchange/${exchange}/new-listings/`}
>
  <div class="listings-page">
    <header class="page-header">
      <div class="container">
        <div class="badge-row">
          <span class="tech-tag">EXCHANGE_INTELLIGENCE</span>
          <span class="live-badge"><span class="dot"></span> LIVE_FEED</span>
        </div>
        <h1 class="glitch-title">{exchange.toUpperCase()} <span class="highlight">LISTINGS</span></h1>
        <p class="header-subtitle">
          Advanced impact scoring and liquidity analysis for the latest assets added to {exchange.toUpperCase()}.
        </p>
      </div>
    </header>

    <main class="main-content">
      <div class="container">
        <div class="listing-grid">
          {listings.map((listing: any) => (
            <ListingCard listing={listing} exchange={exchange} />
          ))}
        </div>

        {listings.length === 0 && (
          <div class="no-results">
            <p>No recent listings detected for this exchange.</p>
          </div>
        )}
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .listings-page { background: var(--color-surface-950); min-height: 100vh; }

  .page-header {
    padding-block: 6rem 4rem;
    background: radial-gradient(circle at 70% 20%, oklch(25% 0.1 195 / 0.15), transparent 50%);
    border-bottom: 1px solid oklch(25% 0.05 195 / 0.3);
  }

  .badge-row { display: flex; gap: 1rem; margin-bottom: 1.5rem; }
  
  .tech-tag {
    font-size: 0.625rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: oklch(20% 0.04 260);
    border: 1px solid oklch(25% 0.05 195 / 0.3);
    border-radius: 2rem;
    color: var(--color-text-secondary);
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.625rem;
    font-weight: 800;
    color: #ff003c;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: #ff003c;
    border-radius: 50%;
    box-shadow: 0 0 8px #ff003c;
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .glitch-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    color: white;
    margin: 0 0 1.5rem;
  }

  .highlight { color: var(--color-brand-400); }

  .header-subtitle { font-size: 1.125rem; color: var(--color-text-secondary); max-width: 600px; }

  .main-content { padding-block: 4rem 8rem; }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) { .listing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1200px) { .listing-grid { grid-template-columns: repeat(3, 1fr); } }

  .no-results {
    text-align: center;
    padding: 4rem;
    color: var(--color-text-muted);
    border: 1px dashed oklch(25% 0.05 195 / 0.3);
    border-radius: 1.5rem;
  }
</style>
